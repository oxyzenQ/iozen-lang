# Test 30: Parser Torture — Everything in one file
# Risk: Interaction bugs between features

print "Test 30: Parser torture"

# All statement types in one function
function torture with n as integer returns integer
    # Variable decl
    create variable x as integer with value n
    
    # If with loop inside
    when x is greater than 0 do
        repeat 2 times do
            set x to x + 1
        end
    end
    
    # Nested if with early return
    when x is greater than 10 do
        when x is less than 100 do
            return x
        end
    end
    
    # While with nested if
    while x is less than 50 do
        when x equals 20 do
            set x to x + 10
        end
        increase x by 1
    end
    
    return x
end

# Call with various inputs
print torture with 5
print torture with 15
print torture with 100

# Complex expression with function calls
function double with x as integer returns integer
    return x * 2
end

function triple with x as integer returns integer
    return x * 3
end

create variable result as integer with value double with triple with 5 + 10
print result

