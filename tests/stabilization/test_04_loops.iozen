# Test 04: Loops - while and repeat
create variable sum as integer with value 0
create variable i as integer with value 1

while i is less than or equal to 10 do
    set sum to sum + i
    increase i by 1
end

print sum

# Repeat loop
repeat 3 times do
    print "repeat"
end

when sum equals 55 do
    print "Test 04: PASS"
otherwise do
    print "Test 04: FAIL"
end
