# Test 62: Parallel For-Each
# Demonstrates parallel iteration with auto chunking

function main returns integer
    print "Testing parallel for-each..."
    
    # Create a list of numbers
    create numbers as list of integer
    
    # Add numbers 1 to 10000
    create i as integer with value 1
    while i <= 10000 do
        append i to numbers
        set i to i + 1
    end
    
    # Sequential for-each (default)
    create sum as integer with value 0
    for each n in numbers do
        set sum to sum + n
    end
    print "Sequential sum: " attach sum
    
    # Parallel for-each (Phase 22)
    # This will auto-chunk and distribute across threads
    # parallel for each n in numbers do
    #     set sum to sum + n
    # end
    
    return 0
end

main()
