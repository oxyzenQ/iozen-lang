# Multiple function definitions
function f1 with x as integer returns integer
    return x + 1
end

function f2 with x as integer returns integer
    return x * 2
end

function f3 with x as integer returns integer
    return x - 1
end

print f1 with 5
print f2 with 5
print f3 with 5

# Long chain of operations
create variable result as integer with value v1 + v2 + v3 + v4 + v5 + v6 + v7 + v8 + v9 + v10
print result

