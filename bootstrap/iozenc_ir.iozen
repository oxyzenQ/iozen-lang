# ============================================================
# IOZENC IR — Internal Representation Compiler v0.1
# Phase 9: Architecture Consolidation — Minimal IR Layer
#
# Pipeline: Source → AST → IR → C99 → Binary
#           (1)   (2)  (3)  (4)    (5)
#
# IR Layer isolates backend from frontend syntax details.
# This enables future backends (LLVM, WASM, etc) without
# touching parser or AST.
# ============================================================

print "╔══════════════════════════════════════════╗"
print "║  IOZENC IR — Architecture Consolidation  ║"
print "║  AST → IR → C99 Compiler                  ║"
print "╚══════════════════════════════════════════╝"
print ""

# ============================================================
# INPUT
# ============================================================
# Test runner - change this to test different files
create variable test_files as list with value [
    "tests/stabilization/test_01_hello.iozen",
    "tests/stabilization/test_02_variables.iozen",
    "tests/stabilization/test_03_functions.iozen",
    "tests/stabilization/test_04_loops.iozen",
    "tests/stabilization/test_05_conditions.iozen",
    "tests/stabilization/test_06_recursion.iozen",
    "tests/stabilization/test_07_strings.iozen",
    "tests/stabilization/test_08_comparisons.iozen",
    "tests/stabilization/test_09_lists.iozen",
    "tests/stabilization/test_10_nested.iozen"
]
create variable current_test as integer with value 0
create variable source_file as text with value test_files[current_test]
create variable source as text with value read_file(source_file)

when source equals "" do
    print "Error: Could not read " attach source_file
    exit
end

print "Compiling: " attach source_file
print ""

# Initialize source tracking for error reporting
set_source_file with source_file
set_source_content with file_content

# ============================================================
# STAGE 0: SYMBOL TABLE CORE + ERROR SYSTEM (Phase 9.3b + 9.3c)
# ============================================================
create variable compiler_errors as integer with value 0
create variable max_errors as integer with value 10

# Source location for error tracking
# Location = { file: text, line: integer, column: integer }
create variable current_file as text with value ""
create variable source_lines as list with value []

function set_source_file with filename as text returns nothing
    set current_file to filename
end

function set_source_content with content as text returns nothing
    # Split content into lines for context
    set source_lines to split(content, "\n")
end

function make_location with line as integer and column as integer returns map
    return map("file", current_file, "line", line, "column", column)
end

function add_error with msg as text and loc as map returns nothing
    print ""
    print "ERROR: " attach msg

    create variable err_file as text with value get_key(loc, "file")
    create variable err_line as integer with value get_key(loc, "line")
    create variable err_col as integer with value get_key(loc, "column")

    when err_line > 0 do
        print " → " attach err_file attach ":" attach err_line attach ":" attach err_col
        print ""

        # Show context (1 line before, error line, 1 line after)
        create variable start_line as integer with value err_line - 1
        when start_line < 1 do set start_line to 1 end

        create variable end_line as integer with value err_line + 1
        when end_line > length(source_lines) do set end_line to length(source_lines) end

        create variable i as integer with value start_line
        while i <= end_line do
            create variable line_content as text with value source_lines[i - 1]
            create variable line_num as text with value i

            when i equals err_line do
                print " > " attach line_num attach " | " attach line_content
                # Print caret pointing to column
                create variable caret_padding as text with value repeat(" ", length(line_num) + 4 + err_col - 1)
                print caret_padding attach "^"
            end
            when i != err_line do
                print "   " attach line_num attach " | " attach line_content
            end
            increase i by 1
        end
    end

    print ""
    set compiler_errors to compiler_errors + 1
    when compiler_errors > max_errors do
        print "Too many errors, stopping."
        stop
    end
end

function repeat with str as text and count as integer returns text
    create variable result as text with value ""
    create variable i as integer with value 0
    while i < count do
        set result to result attach str
        increase i by 1
    end
    return result
end

# ============================================================================
# STANDARD LIBRARY - Minimal but essential
# ============================================================================

# len() - Get length of string or list
function len with value as any returns integer
    create variable vtype as text with value type_of(value)
    when vtype equals "text" do
        return length(value)
    end
    when vtype equals "list" do
        return length(value)
    end
    return 0
end

# to_string() - Convert any value to string representation
function to_string with value as any returns text
    create variable vtype as text with value type_of(value)
    when vtype equals "integer" do
        return value attach ""
    end
    when vtype equals "text" do
        return value
    end
    when vtype equals "boolean" do
        when value do return "true" end
        return "false"
    end
    when vtype equals "list" do
        return "[list of " attach length(value) attach " elements]"
    end
    return ""
end

# substr() - Extract substring (start is inclusive, end is exclusive)
function substr with s as text and start as integer and endpos as integer returns text
    create variable result as text with value ""
    create variable i as integer with value start
    while i < endpos and i < length(s) do
        set result to result attach char_at(s, i)
        increase i by 1
    end
    return result
end

# contains() - Check if string contains substring
function contains with s as text and substr as text returns boolean
    create variable s_len as integer with value length(s)
    create variable sub_len as integer with value length(substr)

    when sub_len > s_len do return false end
    when sub_len equals 0 do return true end

    create variable i as integer with value 0
    while i <= s_len - sub_len do
        create variable matched as boolean with value true
        create variable j as integer with value 0
        while j < sub_len do
            when char_at(s, i + j) != char_at(substr, j) do
                set matched to false
                stop
            end
            increase j by 1
        end
        when matched do return true end
        increase i by 1
    end
    return false
end

# upper() - Convert string to uppercase (basic ASCII only)
function upper with s as text returns text
    # Basic implementation - just return as-is for now
    # Full ASCII upper conversion would need char code manipulation
    return s
end

# lower() - Convert string to lowercase (basic ASCII only)
function lower with s as text returns text
    # Basic implementation - just return as-is for now
    return s
end

# Legacy error for backwards compatibility
function add_error_simple with msg as text returns nothing
    print "ERROR: " attach msg
    set compiler_errors to compiler_errors + 1
    when compiler_errors > max_errors do
        print "Too many errors, stopping."
        stop
    end
end

function has_errors() returns boolean
    return compiler_errors > 0
end

function reset_errors() returns nothing
    set compiler_errors to 0
end

create variable next_symbol_id as integer with value 1
create variable next_scope_id as integer with value 1
create variable scopes as map with value map()
create variable symbols as map with value map()
create variable current_scope_id as integer with value 0

# Scope 0 = global
create variable global_scope as map with value map("id", 0, "parent_id", -1, "syms", map(), "level", 0)
set_key(scopes, 0, global_scope)

# Register built-in stdlib functions in global scope
# These are always available and cannot be shadowed by user code
create variable builtin_funcs as map with value map()
set_key(builtin_funcs, "len", map("sym_id", -1, "sym_type", "function", "data_type", "integer", "is_builtin", true))
set_key(builtin_funcs, "to_string", map("sym_id", -2, "sym_type", "function", "data_type", "text", "is_builtin", true))
set_key(builtin_funcs, "substr", map("sym_id", -3, "sym_type", "function", "data_type", "text", "is_builtin", true))
set_key(builtin_funcs, "contains", map("sym_id", -4, "sym_type", "function", "data_type", "boolean", "is_builtin", true))
set_key(builtin_funcs, "upper", map("sym_id", -5, "sym_type", "function", "data_type", "text", "is_builtin", true))
set_key(builtin_funcs, "lower", map("sym_id", -6, "sym_type", "function", "data_type", "text", "is_builtin", true))

function push_scope() returns integer
    create variable new_scope_id as integer with value next_scope_id
    set next_scope_id to next_scope_id + 1
    create variable current_level as integer with value get_key(scopes[current_scope_id], "level")
    when current_level equals nothing do set current_level to 0 end
    set current_level to current_level + 1
    create variable new_scope as map with value map("id", new_scope_id, "parent_id", current_scope_id, "syms", map(), "level", current_level)
    set_key(scopes, new_scope_id, new_scope)
    set current_scope_id to new_scope_id
    return new_scope_id
end

function pop_scope() returns nothing
    when current_scope_id equals 0 do return end
    set current_scope_id to get_key(scopes[current_scope_id], "parent_id")
end

function lookup_symbol with name as text returns integer
    # Check built-in functions first (cannot be shadowed)
    when has_key(builtin_funcs, name) do
        return get_key(builtin_funcs[name], "sym_id")
    end
    # Then check user-defined symbols in scope chain
    create variable scope_id as integer with value current_scope_id
    while scope_id >= 0 do
        create variable scope as map with value scopes[scope_id]
        create variable scope_syms as map with value get_key(scope, "syms")
        when has_key(scope_syms, name) do
            return get_key(scope_syms, name)
        end
        set scope_id to get_key(scope, "parent_id")
    end
    return -1
end

function declare_symbol with name as text and sym_type as text and data_type as text returns integer
    create variable current_scope as map with value scopes[current_scope_id]
    create variable scope_syms as map with value get_key(current_scope, "syms")
    when has_key(scope_syms, name) do
        add_error with "Duplicate declaration of '" attach name attach "'"
        return -1
    end
    create variable symbol_id as integer with value next_symbol_id
    set next_symbol_id to next_symbol_id + 1
    create variable sym as map with value map("id", symbol_id, "nm", name, "scope_id", current_scope_id, "tp", sym_type, "dt", data_type)
    set_key(symbols, symbol_id, sym)
    set_key(scope_syms, name, symbol_id)
    return symbol_id
end

function get_symbol with symbol_id as integer returns map
    when has_key(symbols, symbol_id) do return symbols[symbol_id] end
    return map()
end

function symbol_id_to_c_name with symbol_id as integer returns text
    create variable sym as map with value get_symbol(symbol_id)
    create variable sym_nm as text with value get_key(sym, "nm")
    when sym_nm equals nothing do return "unknown" end
    return sym_nm attach "_" attach symbol_id
end

function dump_symbol_table() returns text
    create variable out as text with value "=== SYMBOL TABLE ===\n"
    set out to out attach "Total symbols: " attach (next_symbol_id - 1) attach "\n"
    set out to out attach "Total scopes: " attach next_scope_id attach "\n\n"

    create variable i as integer with value 1
    while i < next_symbol_id do
        when has_key(symbols, i) do
            create variable sym as map with value symbols[i]
            set out to out attach "Symbol " attach i attach ":\n"
            set out to out attach "  name: " attach get_key(sym, "nm") attach "\n"
            set out to out attach "  type: " attach get_key(sym, "tp") attach "\n"
            set out to out attach "  data_type: " attach get_key(sym, "dt") attach "\n"
            set out to out attach "  scope_id: " attach get_key(sym, "scope_id") attach "\n\n"
        end
        increase i by 1
    end
    return out
end

# ============================================================
# STAGE 1-2: LEXER + PARSER (reused from iozenc.iozen)
# ============================================================
create variable lex_pos as integer with value 0
create variable lex_len as integer with value length(source)
create variable tokens as list with value []

function lex_is_alpha(ch) returns boolean
    create variable c as integer with value ord(ch)
    when c >= 97 and c <= 122 do return true end
    when c >= 65 and c <= 90 do return true end
    when c equals 95 do return true end
    return false
end

function lex_is_digit(ch) returns boolean
    create variable c as integer with value ord(ch)
    when c >= 48 and c <= 57 do return true end
    return false
end

function lex_is_alnum(ch) returns boolean
    when lex_is_alpha(ch) do return true end
    return lex_is_digit(ch)
end

function lex_is_keyword(word) returns boolean
    when word equals "print" do return true end
    when word equals "create" do return true end
    when word equals "variable" do return true end
    when word equals "as" do return true end
    when word equals "with" do return true end
    when word equals "value" do return true end
    when word equals "integer" do return true end
    when word equals "float" do return true end
    when word equals "text" do return true end
    when word equals "boolean" do return true end
    when word equals "function" do return true end
    when word equals "returns" do return true end
    when word equals "return" do return true end
    when word equals "end" do return true end
    when word equals "when" do return true end
    when word equals "otherwise" do return true end
    when word equals "do" do return true end
    when word equals "while" do return true end
    when word equals "repeat" do return true end
    when word equals "times" do return true end
    when word equals "and" do return true end
    when word equals "or" do return true end
    when word equals "not" do return true end
    when word equals "is" do return true end
    when word equals "true" do return true end
    when word equals "false" do return true end
    when word equals "nothing" do return true end
    when word equals "increase" do return true end
    when word equals "decrease" do return true end
    when word equals "by" do return true end
    when word equals "set" do return true end
    when word equals "to" do return true end
    when word equals "attach" do return true end
    when word equals "greater" do return true end
    when word equals "less" do return true end
    when word equals "than" do return true end
    when word equals "equal" do return true end
    when word equals "equals" do return true end
    return false
end

function lex_read_ident() returns list
    create variable word as text with value ""
    while lex_pos < lex_len and lex_is_alnum(char_at(source, lex_pos)) do
        set word to word attach char_at(source, lex_pos)
        set lex_pos to lex_pos + 1
    end
    when lex_is_keyword(word) do
        return [word, word]
    end
    return ["IDENT", word]
end

function lex_read_num() returns list
    create variable num as text with value ""
    while lex_pos < lex_len and lex_is_digit(char_at(source, lex_pos)) do
        set num to num attach char_at(source, lex_pos)
        set lex_pos to lex_pos + 1
    end
    return ["INT", num]
end

function lex_read_str() returns list
    set lex_pos to lex_pos + 1
    create variable str as text with value ""
    while lex_pos < lex_len do
        create variable ch as text with value char_at(source, lex_pos)
        when ch equals "\"" do
            set lex_pos to lex_pos + 1
            return ["STR", str]
        end
        set str to str attach ch
        set lex_pos to lex_pos + 1
    end
    return ["STR", str]
end

# Location-aware versions of lexer helpers
function lex_read_ident_with_loc with line as integer and col as integer returns list
    create variable word as text with value ""
    while lex_pos < lex_len and lex_is_alnum(char_at(source, lex_pos)) do
        set word to word attach char_at(source, lex_pos)
        set lex_pos to lex_pos + 1
    end
    # Check for keywords
    when word equals "create" do return ["CREATE", "create", line, col] end
    when word equals "variable" do return ["VAR", "variable", line, col] end
    when word equals "as" do return ["AS", "as", line, col] end
    when word equals "with" do return ["WITH", "with", line, col] end
    when word equals "value" do return ["VALUE", "value", line, col] end
    when word equals "integer" do return ["INTTYPE", "integer", line, col] end
    when word equals "text" do return ["TEXTTYPE", "text", line, col] end
    when word equals "boolean" do return ["BOOLEANTYPE", "boolean", line, col] end
    when word equals "nothing" do return ["NOTHINGTYPE", "nothing", line, col] end
    when word equals "set" do return ["SET", "set", line, col] end
    when word equals "to" do return ["TO", "to", line, col] end
    when word equals "when" do return ["WHEN", "when", line, col] end
    when word equals "do" do return ["DO", "do", line, col] end
    when word equals "else" do return ["ELSE", "else", line, col] end
    when word equals "end" do return ["END", "end", line, col] end
    when word equals "while" do return ["WHILE", "while", line, col] end
    when word equals "repeat" do return ["REPEAT", "repeat", line, col] end
    when word equals "times" do return ["TIMES", "times", line, col] end
    when word equals "for" do return ["FOR", "for", line, col] end
    when word equals "from" do return ["FROM", "from", line, col] end
    when word equals "return" do return ["RETURN", "return", line, col] end
    when word equals "returns" do return ["RETURNS", "returns", line, col] end
    when word equals "function" do return ["FUNCTION", "function", line, col] end
    when word equals "stop" do return ["STOP", "stop", line, col] end
    when word equals "or" do return ["OR", "or", line, col] end
    when word equals "and" do return ["AND", "and", line, col] end
    when word equals "not" do return ["NOT", "not", line, col] end
    when word equals "equals" do return ["EQUALS", "equals", line, col] end
    when word equals "print" do return ["PRINT", "print", line, col] end
    when word equals "true" do return ["BOOL", "true", line, col] end
    when word equals "false" do return ["BOOL", "false", line, col] end
    when word equals "map" do return ["MAP", "map", line, col] end
    when word equals "list" do return ["LIST", "list", line, col] end
    when word equals "has_key" do return ["HAS_KEY", "has_key", line, col] end
    when word equals "get_key" do return ["GET_KEY", "get_key", line, col] end
    when word equals "set_key" do return ["SET_KEY", "set_key", line, col] end
    when word equals "delete_key" do return ["DELETE_KEY", "delete_key", line, col] end
    when word equals "length" do return ["LENGTH", "length", line, col] end
    when word equals "push" do return ["PUSH", "push", line, col] end
    when word equals "pop" do return ["POP", "pop", line, col] end
    when word equals "insert" do return ["INSERT", "insert", line, col] end
    when word equals "increase" do return ["INCREASE", "increase", line, col] end
    when word equals "decrease" do return ["DECREASE", "decrease", line, col] end
    when word equals "by" do return ["BY", "by", line, col] end
    when word equals "attach" do return ["ATTACH", "attach", line, col] end
    when word equals "split" do return ["SPLIT", "split", line, col] end
    return ["IDENT", word, line, col]
end

function lex_read_num_with_loc with line as integer and col as integer returns list
    create variable num as text with value ""
    while lex_pos < lex_len and lex_is_digit(char_at(source, lex_pos)) do
        set num to num attach char_at(source, lex_pos)
        set lex_pos to lex_pos + 1
    end
    return ["INT", num, line, col]
end

function lex_read_str_with_loc with line as integer and col as integer returns list
    set lex_pos to lex_pos + 1
    create variable str as text with value ""
    while lex_pos < lex_len do
        create variable ch as text with value char_at(source, lex_pos)
        when ch equals "\"" do
            set lex_pos to lex_pos + 1
            return ["STR", str, line, col]
        end
        set str to str attach ch
        set lex_pos to lex_pos + 1
    end
    return ["STR", str, line, col]
end

function tokenize() returns list
    create variable matched as boolean with value false
    create variable current_line as integer with value 1
    create variable current_col as integer with value 1
    create variable line_start_pos as integer with value 0

    while lex_pos < lex_len do
        while lex_pos < lex_len and char_at(source, lex_pos) equals " " do
            set lex_pos to lex_pos + 1
            set current_col to current_col + 1
        end
        when lex_pos >= lex_len do return tokens end
        create variable ch as text with value char_at(source, lex_pos)
        set matched to false

        # Track newlines for line counting
        when ch equals "\n" do
            set lex_pos to lex_pos + 1
            set current_line to current_line + 1
            set current_col to 1
            set line_start_pos to lex_pos
            set matched to true
        end
        when ch equals "\t" or ch equals "\r" do
            set lex_pos to lex_pos + 1
            set current_col to current_col + 1
            set matched to true
        end

        when ch equals "#" do
            while lex_pos < lex_len and char_at(source, lex_pos) != "\n" do
                set lex_pos to lex_pos + 1
            end
            set matched to true
        end
        when ch equals "\"" do
            push(tokens, lex_read_str_with_loc(current_line, current_col))
            set matched to true
        end
        when lex_is_digit(ch) do
            push(tokens, lex_read_num_with_loc(current_line, current_col))
            set matched to true
        end
        when lex_is_alpha(ch) do
            push(tokens, lex_read_ident_with_loc(current_line, current_col))
            set matched to true
        end
        when ch equals "+" do push(tokens, ["PLUS", "+", current_line, current_col]) set lex_pos to lex_pos + 1 set current_col to current_col + 1 set matched to true end
        when ch equals "-" do push(tokens, ["MINUS", "-", current_line, current_col]) set lex_pos to lex_pos + 1 set current_col to current_col + 1 set matched to true end
        when ch equals "*" do push(tokens, ["STAR", "*", current_line, current_col]) set lex_pos to lex_pos + 1 set current_col to current_col + 1 set matched to true end
        when ch equals "/" do push(tokens, ["SLASH", "/", current_line, current_col]) set lex_pos to lex_pos + 1 set current_col to current_col + 1 set matched to true end
        when ch equals "%" do push(tokens, ["PERCENT", "%", current_line, current_col]) set lex_pos to lex_pos + 1 set current_col to current_col + 1 set matched to true end
        when ch equals "," do push(tokens, ["COMMA", ",", current_line, current_col]) set lex_pos to lex_pos + 1 set current_col to current_col + 1 set matched to true end
        when ch equals "(" do push(tokens, ["LPAREN", "(", current_line, current_col]) set lex_pos to lex_pos + 1 set current_col to current_col + 1 set matched to true end
        when ch equals ")" do push(tokens, ["RPAREN", ")", current_line, current_col]) set lex_pos to lex_pos + 1 set current_col to current_col + 1 set matched to true end
        when ch equals "=" do push(tokens, ["ASSIGN", "=", current_line, current_col]) set lex_pos to lex_pos + 1 set current_col to current_col + 1 set matched to true end
        when matched equals false and lex_pos < lex_len do
            set lex_pos to lex_pos + 1
            set current_col to current_col + 1
        end
    end
    return tokens
end

# Parser
create variable par_pos as integer with value 0

function par_peek() returns list
    when par_pos >= length(tokens) do return ["EOF", "", 0, 0] end
    return tokens[par_pos]
end

function par_advance() returns list
    create variable tok as list with value par_peek()
    when par_pos < length(tokens) do set par_pos to par_pos + 1 end
    return tok
end

function par_tok_is with expected as text returns boolean
    create variable t as list with value par_peek()
    return t[0] equals expected or t[1] equals expected
end

function par_expect with expected as text returns list
    create variable t as list with value par_peek()
    when t[0] equals expected or t[1] equals expected do
        return par_advance()
    end
    return t
end

function parse_expression() returns map
    return parse_comparison()
end

function parse_comparison() returns map
    create variable left as map with value parse_addition()
    while par_tok_is with "EQ" or par_tok_is with "NEQ" or par_tok_is with "LT" or par_tok_is with "GT" or par_tok_is with "LTE" or par_tok_is with "GTE" do
        create variable op_tok as list with value par_advance()
        create variable right as map with value parse_addition()
        set left to map("kind", "BinaryExpr", "operator", op_tok[1], "left", left, "right", right)
    end
    while par_tok_is with "equals" do
        par_advance()
        create variable right as map with value parse_addition()
        set left to map("kind", "BinaryExpr", "operator", "==", "left", left, "right", right)
    end
    while par_tok_is with "is" do
        par_advance()
        create variable op as text with value ""
        when par_tok_is with "greater" do
            par_advance()
            par_expect with "than"
            set op to ">"
            when par_tok_is with "or" do
                par_advance()
                par_expect with "equal"
                par_expect with "to"
                set op to ">="
            end
        end
        when par_tok_is with "less" do
            par_advance()
            par_expect with "than"
            set op to "<"
            when par_tok_is with "or" do
                par_advance()
                par_expect with "equal"
                par_expect with "to"
                set op to "<="
            end
        end
        create variable right as map with value parse_addition()
        set left to map("kind", "BinaryExpr", "operator", op, "left", left, "right", right)
    end
    return left
end

function parse_addition() returns map
    create variable left as map with value parse_multiply()
    while par_tok_is with "PLUS" or par_tok_is with "MINUS" do
        create variable op_tok as list with value par_advance()
        create variable right as map with value parse_multiply()
        set left to map("kind", "BinaryExpr", "operator", op_tok[1], "left", left, "right", right)
    end
    return left
end

function parse_multiply() returns map
    create variable left as map with value parse_unary()
    while par_tok_is with "STAR" or par_tok_is with "SLASH" or par_tok_is with "PERCENT" do
        create variable op_tok as list with value par_advance()
        create variable right as map with value parse_unary()
        set left to map("kind", "BinaryExpr", "operator", op_tok[1], "left", left, "right", right)
    end
    return left
end

function parse_unary() returns map
    when par_tok_is with "MINUS" do
        create variable op as list with value par_advance()
        create variable operand as map with value parse_unary()
        return map("kind", "UnaryExpr", "operator", op[1], "operand", operand)
    end
    when par_tok_is with "not" do
        par_advance()
        create variable operand as map with value parse_unary()
        return map("kind", "UnaryExpr", "operator", "not", "operand", operand)
    end
    return parse_postfix()
end

function parse_postfix() returns map
    create variable expr as map with value parse_primary()
    when par_tok_is with "LPAREN" do
        when get_key(expr, "kind") equals "Identifier" do
            par_advance()
            create variable args as list with value []
            when not (par_tok_is with "RPAREN") do
                push(args, parse_expression())
                while par_tok_is with "COMMA" do
                    par_advance()
                    push(args, parse_expression())
                end
            end
            par_expect with "RPAREN"
            return map("kind", "FunctionCallExpr", "name", get_key(expr, "name"), "arguments", args)
        end
    end
    return expr
end

function parse_primary() returns map
    when par_tok_is with "INT" do
        create variable tok as list with value par_advance()
        return map("kind", "Literal", "type", "integer", "value", to_integer(tok[1]))
    end
    when par_tok_is with "STR" do
        create variable tok as list with value par_advance()
        return map("kind", "Literal", "type", "text", "value", tok[1])
    end
    when par_tok_is with "true" do
        par_advance()
        return map("kind", "Literal", "type", "boolean", "value", true)
    end
    when par_tok_is with "false" do
        par_advance()
        return map("kind", "Literal", "type", "boolean", "value", false)
    end
    when par_tok_is with "nothing" do
        par_advance()
        return map("kind", "Literal", "type", "nothing", "value", nothing)
    end
    when par_tok_is with "LPAREN" do
        par_advance()
        create variable expr as map with value parse_expression()
        par_expect with "RPAREN"
        return expr
    end
    when par_tok_is with "IDENT" do
        create variable tok as list with value par_advance()
        when par_tok_is with "LPAREN" do
            par_advance()
            create variable args as list with value []
            when not (par_tok_is with "RPAREN") do
                push(args, parse_expression())
                while par_tok_is with "COMMA" do
                    par_advance()
                    push(args, parse_expression())
                end
            end
            par_expect with "RPAREN"
            return map("kind", "FunctionCallExpr", "name", tok[1], "arguments", args)
        end
        when par_tok_is with "with" do
            par_advance()
            create variable args as list with value []
            push(args, parse_expression())
            while par_tok_is with "and" do
                par_advance()
                push(args, parse_expression())
            end
            return map("kind", "FunctionCallExpr", "name", tok[1], "arguments", args)
        end
        return map("kind", "Identifier", "name", tok[1])
    end
    par_advance()
    return map("kind", "Literal", "type", "nothing", "value", nothing)
end

function parse_statement() returns map
    when par_tok_is with "print" do
        par_advance()
        create variable expr as map with value parse_expression()
        return map("kind", "PrintStmt", "expressions", [expr])
    end
    when par_tok_is with "create" do
        par_advance()
        when par_tok_is with "constant" do par_advance() end
        par_expect with "variable"
        create variable name_tok as list with value par_expect with "IDENT"
        create variable type_name as text with value "unknown"
        when par_tok_is with "as" do
            par_advance()
            create variable type_tok as list with value par_advance()
            set type_name to type_tok[1]
        end
        create variable val as map with value nothing
        when par_tok_is with "with" do
            par_advance()
            par_expect with "value"
            set val to parse_expression()
        end
        return map("kind", "VariableDecl", "name", name_tok[1], "typeName", type_name, "isConstant", false, "value", val)
    end
    when par_tok_is with "set" do
        par_advance()
        create variable name_tok as list with value par_expect with "IDENT"
        par_expect with "to"
        create variable val as map with value parse_expression()
        return map("kind", "AssignVar", "name", name_tok[1], "value", val)
    end
    when par_tok_is with "return" do
        par_advance()
        when par_tok_is with "end" or par_tok_is with "EOF" do
            return map("kind", "ReturnStmt", "value", nothing)
        end
        create variable val as map with value parse_expression()
        return map("kind", "ReturnStmt", "value", val)
    end
    when par_tok_is with "when" do
        par_advance()
        create variable cond as map with value parse_expression()
        par_expect with "do"
        create variable body as list with value []
        while not (par_tok_is with "end") and not (par_tok_is with "otherwise") and not (par_tok_is with "EOF") do
            push(body, parse_statement())
        end
        create variable branches as list with value [map("kind", "WhenBranch", "condition", cond, "body", body)]
        create variable otherwise_body as list with value []
        when par_tok_is with "otherwise" do
            par_advance()
            par_expect with "do"
            while not (par_tok_is with "end") and not (par_tok_is with "EOF") do
                push(otherwise_body, parse_statement())
            end
        end
        par_expect with "end"
        return map("kind", "When", "branches", branches, "otherwise", otherwise_body)
    end
    when par_tok_is with "while" do
        par_advance()
        create variable cond as map with value parse_expression()
        par_expect with "do"
        create variable body as list with value []
        while not (par_tok_is with "end") and not (par_tok_is with "EOF") do
            push(body, parse_statement())
        end
        par_expect with "end"
        return map("kind", "While", "condition", cond, "body", body)
    end
    when par_tok_is with "repeat" do
        par_advance()
        create variable count as map with value parse_expression()
        par_expect with "times"
        par_expect with "do"
        create variable body as list with value []
        while not (par_tok_is with "end") and not (par_tok_is with "EOF") do
            push(body, parse_statement())
        end
        par_expect with "end"
        return map("kind", "Repeat", "count", count, "body", body)
    end
    when par_tok_is with "increase" do
        par_advance()
        create variable target as map with value parse_expression()
        par_expect with "by"
        create variable amount as map with value parse_expression()
        return map("kind", "Increase", "target", target, "amount", amount)
    end
    when par_tok_is with "function" do
        par_advance()
        create variable name_tok as list with value par_expect with "IDENT"
        create variable params as list with value []
        when par_tok_is with "with" do
            par_advance()
            while par_tok_is with "IDENT" do
                create variable pname as list with value par_expect with "IDENT"
                par_expect with "as"
                create variable ptype as list with value par_advance()
                push(params, map("name", pname[1], "typeName", ptype[1]))
            end
        end
        create variable ret_type as text with value "nothing"
        when par_tok_is with "returns" do
            par_advance()
            create variable rt as list with value par_advance()
            set ret_type to rt[1]
        end
        create variable body as list with value []
        while not (par_tok_is with "end") and not (par_tok_is with "EOF") do
            push(body, parse_statement())
        end
        par_expect with "end"
        return map("kind", "FunctionDecl", "name", name_tok[1], "parameters", params, "returnType", ret_type, "body", body)
    end
    when par_tok_is with "EOF" do
        return map("kind", "ExprStmt", "expression", map("kind", "Literal", "type", "nothing", "value", nothing))
    end
    par_advance()
    return map("kind", "ExprStmt", "expression", map("kind", "Literal", "type", "nothing", "value", nothing))
end

function parse_program() returns map
    create variable stmts as list with value []
    while not (par_tok_is with "EOF") do
        push(stmts, parse_statement())
    end
    return map("kind", "Program", "statements", stmts)
end

# ============================================================
# STAGE 3: AST → IR TRANSFORMER (NEW IR LAYER)
# ============================================================

# IR Expression Types:
# - IRLiteral: {type, value}
# - IRVariable: {name}
# - IRBinaryOp: {op, left, right}
# - IRUnaryOp: {op, operand}
# - IRCall: {func, args}

# IR Statement Types:
# - IRVarDecl: {name, type, init}
# - IRAssign: {name, value}
# - IRPrint: {value}
# - IRReturn: {value}
# - IRIf: {cond, then_body, else_body}
# - IRWhile: {cond, body}
# - IRRepeat: {count, body}
# - IRBlock: {stmts}

# IR Function: {name, params, ret_type, body}
# IR Module: {functions, globals}

# ============================================================
# PASS 1: DECLARE SYMBOLS (collect all declarations)
# ============================================================

function pass1_declare(ast_node) returns nothing
    create variable node_kind as text with value get_key(ast_node, "kind")

    when node_kind equals "VariableDecl" do
        create variable var_name as text with value get_key(ast_node, "name")
        create variable var_type as text with value get_key(ast_node, "typeName")
        declare_symbol with var_name and "variable" and var_type
    end

    when node_kind equals "FunctionDecl" do
        create variable func_name as text with value get_key(ast_node, "name")
        create variable ret_type as text with value get_key(ast_node, "returnType")
        declare_symbol with func_name and "function" and ret_type
        push_scope()
        create variable params as list with value get_key(ast_node, "parameters")
        create variable i as integer with value 0
        while i < length(params) do
            create variable p as map with value params[i]
            declare_symbol with get_key(p, "name") and "parameter" and get_key(p, "typeName")
            increase i by 1
        end
        create variable body as list with value get_key(ast_node, "body")
        set i to 0
        while i < length(body) do
            pass1_declare(body[i])
            increase i by 1
        end
        pop_scope()
    end

    when node_kind equals "When" do
        create variable branches as list with value get_key(ast_node, "branches")
        create variable i as integer with value 0
        while i < length(branches) do
            create variable branch as map with value branches[i]
            push_scope()
            create var_body as list with value get_key(branch, "body")
            create variable j as integer with value 0
            while j < length(var_body) do
                pass1_declare(var_body[j])
                increase j by 1
            end
            pop_scope()
            increase i by 1
        end
        create variable else_branch as list with value get_key(ast_node, "otherwise")
        when length(else_branch) > 0 do
            push_scope()
            set i to 0
            while i < length(else_branch) do
                pass1_declare(else_branch[i])
                increase i by 1
            end
            pop_scope()
        end
    end

    when node_kind equals "While" do
        push_scope()
        create variable body as list with value get_key(ast_node, "body")
        create variable i as integer with value 0
        while i < length(body) do
            pass1_declare(body[i])
            increase i by 1
        end
        pop_scope()
    end

    when node_kind equals "Repeat" do
        push_scope()
        create variable body as list with value get_key(ast_node, "body")
        create variable i as integer with value 0
        while i < length(body) do
            pass1_declare(body[i])
            increase i by 1
        end
        pop_scope()
    end

    when node_kind equals "BinaryExpr" do
        pass1_declare(get_key(ast_node, "left"))
        pass1_declare(get_key(ast_node, "right"))
    end

    when node_kind equals "UnaryExpr" do
        pass1_declare(get_key(ast_node, "operand"))
    end

    when node_kind equals "FunctionCallExpr" do
        create variable args as list with value get_key(ast_node, "arguments")
        create variable i as integer with value 0
        while i < length(args) do
            pass1_declare(args[i])
            increase i by 1
        end
    end

    when node_kind equals "AssignVar" do
        pass1_declare(get_key(ast_node, "value"))
    end

    when node_kind equals "ReturnStmt" do
        create variable ret_val as map with value get_key(ast_node, "value")
        when not (ret_val equals nothing) do pass1_declare(ret_val) end
    end

    when node_kind equals "PrintStmt" do
        create variable exprs as list with value get_key(ast_node, "expressions")
        create variable i as integer with value 0
        while i < length(exprs) do
            pass1_declare(exprs[i])
            increase i by 1
        end
    end

    when node_kind equals "Program" do
        create variable stmts as list with value get_key(ast_node, "statements")
        create variable i as integer with value 0
        while i < length(stmts) do
            pass1_declare(stmts[i])
            increase i by 1
        end
    end
end

# ============================================================
# PASS 2: RESOLVE IDENTIFIERS TO SYMBOLREF
# ============================================================

function pass2_resolve(ast_node) returns map
    create variable node_kind as text with value get_key(ast_node, "kind")

    when node_kind equals "Identifier" do
        create variable var_name as text with value get_key(ast_node, "name")
        create variable symbol_id as integer with value lookup_symbol with var_name
        when symbol_id equals -1 do
            add_error with "Undefined variable '" attach var_name attach "'"
            return map("kind", "SymbolRef", "symbol_id", -1, "nm", var_name, "err", true)
        end
        return map("kind", "SymbolRef", "symbol_id", symbol_id, "nm", var_name)
    end

    when node_kind equals "BinaryExpr" do
        return map("kind", "BinaryExpr", "op", get_key(ast_node, "operator"), "left", pass2_resolve(get_key(ast_node, "left")), "right", pass2_resolve(get_key(ast_node, "right")))
    end

    when node_kind equals "UnaryExpr" do
        return map("kind", "UnaryExpr", "op", get_key(ast_node, "operator"), "operand", pass2_resolve(get_key(ast_node, "operand")))
    end

    when node_kind equals "FunctionCallExpr" do
        create variable func_name as text with value get_key(ast_node, "name")
        create variable func_id as integer with value lookup_symbol with func_name
        when func_id equals -1 do
            add_error with "Undefined function '" attach func_name attach "'"
        end
        create variable args as list with value get_key(ast_node, "arguments")
        create variable resolved_args as list with value []
        create variable i as integer with value 0
        while i < length(args) do
            push(resolved_args, pass2_resolve(args[i]))
            increase i by 1
        end
        return map("kind", "FunctionCallExpr", "nm", func_name, "sym_id", func_id, "args", resolved_args)
    end

    when node_kind equals "VariableDecl" do
        create variable var_name as text with value get_key(ast_node, "name")
        create variable sym_id as integer with value lookup_symbol with var_name
        create variable init as map with value get_key(ast_node, "value")
        when not (init equals nothing) do set init to pass2_resolve(init) end
        return map("kind", "VariableDecl", "nm", var_name, "sym_id", sym_id, "tp", get_key(ast_node, "typeName"), "init", init)
    end

    when node_kind equals "AssignVar" do
        create variable var_name as text with value get_key(ast_node, "name")
        create variable sym_id as integer with value lookup_symbol with var_name
        when sym_id equals -1 do
            add_error with "Assignment to undefined variable '" attach var_name attach "'"
        end
        return map("kind", "AssignVar", "nm", var_name, "sym_id", sym_id, "val", pass2_resolve(get_key(ast_node, "value")))
    end

    when node_kind equals "ReturnStmt" do
        create variable ret_val as map with value get_key(ast_node, "value")
        when not (ret_val equals nothing) do set ret_val to pass2_resolve(ret_val) end
        return map("kind", "ReturnStmt", "val", ret_val)
    end

    when node_kind equals "PrintStmt" do
        create variable exprs as list with value get_key(ast_node, "expressions")
        create variable resolved_exprs as list with value []
        create variable i as integer with value 0
        while i < length(exprs) do
            push(resolved_exprs, pass2_resolve(exprs[i]))
            increase i by 1
        end
        return map("kind", "PrintStmt", "exprs", resolved_exprs)
    end

    when node_kind equals "FunctionDecl" do
        push_scope()
        create variable params as list with value get_key(ast_node, "parameters")
        create variable i as integer with value 0
        while i < length(params) do
            create variable p as map with value params[i]
            declare_symbol with get_key(p, "name") and "parameter" and get_key(p, "typeName")
            increase i by 1
        end
        create variable body as list with value get_key(ast_node, "body")
        create variable resolved_body as list with value []
        set i to 0
        while i < length(body) do
            push(resolved_body, pass2_resolve(body[i]))
            increase i by 1
        end
        pop_scope()
        return map("kind", "FunctionDecl", "nm", get_key(ast_node, "name"), "params", params, "ret", get_key(ast_node, "returnType"), "body", resolved_body)
    end

    when node_kind equals "When" do
        create variable resolved_branches as list with value []
        create variable branches as list with value get_key(ast_node, "branches")
        create variable i as integer with value 0
        while i < length(branches) do
            create variable branch as map with value branches[i]
            push_scope()
            create var_body as list with value get_key(branch, "body")
            create variable resolved_branch_body as list with value []
            create variable j as integer with value 0
            while j < length(var_body) do
                push(resolved_branch_body, pass2_resolve(var_body[j]))
                increase j by 1
            end
            pop_scope()
            push(resolved_branches, map("kind", "WhenBranch", "cond", pass2_resolve(get_key(branch, "condition")), "body", resolved_branch_body))
            increase i by 1
        end
        create variable resolved_else as list with value []
        create variable else_branch as list with value get_key(ast_node, "otherwise")
        when length(else_branch) > 0 do
            push_scope()
            set i to 0
            while i < length(else_branch) do
                push(resolved_else, pass2_resolve(else_branch[i]))
                increase i by 1
            end
            pop_scope()
        end
        return map("kind", "When", "branches", resolved_branches, "else", resolved_else)
    end

    when node_kind equals "While" do
        push_scope()
        create variable body as list with value get_key(ast_node, "body")
        create variable resolved_body as list with value []
        create variable i as integer with value 0
        while i < length(body) do
            push(resolved_body, pass2_resolve(body[i]))
            increase i by 1
        end
        pop_scope()
        return map("kind", "While", "cond", pass2_resolve(get_key(ast_node, "condition")), "body", resolved_body)
    end

    when node_kind equals "Repeat" do
        push_scope()
        create variable body as list with value get_key(ast_node, "body")
        create variable resolved_body as list with value []
        create variable i as integer with value 0
        while i < length(body) do
            push(resolved_body, pass2_resolve(body[i]))
            increase i by 1
        end
        pop_scope()
        return map("kind", "Repeat", "cnt", pass2_resolve(get_key(ast_node, "count")), "body", resolved_body)
    end

    when node_kind equals "Program" do
        create variable stmts as list with value get_key(ast_node, "statements")
        create variable resolved_stmts as list with value []
        create variable i as integer with value 0
        while i < length(stmts) do
            push(resolved_stmts, pass2_resolve(stmts[i]))
            increase i by 1
        end
        return map("kind", "Program", "stmts", resolved_stmts)
    end

    return ast_node
end

# ============================================================
# RETURN PATH COMPLETENESS CHECK (Phase 9.3c)
# ============================================================

function has_return_stmt with stmts as list returns boolean
    create variable i as integer with value 0
    while i < length(stmts) do
        create variable stmt as map with value stmts[i]
        create variable stmt_kind as text with value get_key(stmt, "kind")
        when stmt_kind equals "ReturnStmt" do return true end
        when stmt_kind equals "When" do
            # Check all branches have return
            create variable branches as list with value get_key(stmt, "branches")
            create variable all_return as boolean with value true
            create variable j as integer with value 0
            while j < length(branches) do
                create variable branch_body as list with value get_key(branches[j], "body")
                when not (has_return_stmt with branch_body) do
                    set all_return to false
                end
                increase j by 1
            end
            # Check else branch
            create variable else_body as list with value get_key(stmt, "else")
            when not (has_return_stmt with else_body) do
                set all_return to false
            end
            when all_return equals true do return true end
        end
        increase i by 1
    end
    return false
end

function check_return_paths with ast_node as map returns nothing
    create variable node_kind as text with value get_key(ast_node, "kind")
    when node_kind equals "FunctionDecl" do
        create variable ret_type as text with value get_key(ast_node, "ret")
        when not (ret_type equals "nothing") do
            create variable body as list with value get_key(ast_node, "body")
            when not (has_return_stmt with body) do
                add_error with "Function '" attach get_key(ast_node, "nm") attach "' missing return path"
            end
        end
    end
    when node_kind equals "Program" do
        create variable stmts as list with value get_key(ast_node, "stmts")
        create variable i as integer with value 0
        while i < length(stmts) do
            check_return_paths(stmts[i])
            increase i by 1
        end
    end
end

# ============================================================
# CONSTANT PROPAGATION (Phase 10.5)
# ============================================================

function propagate_ir_expr with ir_expr as map and env as map returns map
    create variable etype as text with value get_key(ir_expr, "type")

    when etype equals "IRSymbolRef" do
        create variable sym_id as integer with value get_key(ir_expr, "symbol_id")
        when has_key(env, sym_id) do
            # Replace variable reference with its constant value
            return env[sym_id]
        end
        return ir_expr
    end

    when etype equals "IRBinaryOp" do
        create variable left_prop as map with value propagate_ir_expr(get_key(ir_expr, "left"), env)
        create variable right_prop as map with value propagate_ir_expr(get_key(ir_expr, "right"), env)
        return map("type", "IRBinaryOp", "op", get_key(ir_expr, "op"), "left", left_prop, "right", right_prop, "data_type", get_key(ir_expr, "data_type"))
    end

    when etype equals "IRUnaryOp" do
        return map("type", "IRUnaryOp", "op", get_key(ir_expr, "op"), "operand", propagate_ir_expr(get_key(ir_expr, "operand"), env), "data_type", get_key(ir_expr, "data_type"))
    end

    when etype equals "IRCall" do
        # Propagate in arguments, but don't propagate the call itself
        create variable args as list with value get_key(ir_expr, "args")
        create variable prop_args as list with value []
        create variable i as integer with value 0
        while i < length(args) do
            push(prop_args, propagate_ir_expr(args[i], env))
            increase i by 1
        end
        return map("type", "IRCall", "func", get_key(ir_expr, "func"), "args", prop_args, "data_type", get_key(ir_expr, "data_type"))
    end

    # IRLiteral and others - return as-is
    return ir_expr
end

function propagate_ir_stmt with ir_stmt as map and env as map returns map
    create variable stype as text with value get_key(ir_stmt, "type")

    when stype equals "IRVarDecl" do
        create variable prop_init as map with value propagate_ir_expr(get_key(ir_stmt, "init"), env)

        # If initialized with literal, add to environment
        when get_key(prop_init, "type") equals "IRLiteral" do
            create variable sym_id as integer with value get_key(ir_stmt, "symbol_id")
            set_key(env, sym_id, prop_init)
        end

        return map("type", "IRVarDecl", "name", get_key(ir_stmt, "name"), "symbol_id", get_key(ir_stmt, "symbol_id"), "var_type", get_key(ir_stmt, "var_type"), "init", prop_init)
    end

    when stype equals "IRAssign" do
        create variable prop_value as map with value propagate_ir_expr(get_key(ir_stmt, "value"), env)

        # If assigning a literal, update environment
        # If not, remove from environment (variable is no longer constant)
        create variable sym_id as integer with value get_key(ir_stmt, "symbol_id")
        when get_key(prop_value, "type") equals "IRLiteral" do
            set_key(env, sym_id, prop_value)
        end
        when get_key(prop_value, "type") != "IRLiteral" do
            when has_key(env, sym_id) do
                delete_key(env, sym_id)
            end
        end

        return map("type", "IRAssign", "name", get_key(ir_stmt, "name"), "symbol_id", sym_id, "value", prop_value)
    end

    when stype equals "IRReturn" do
        return map("type", "IRReturn", "value", propagate_ir_expr(get_key(ir_stmt, "value"), env))
    end

    when stype equals "IRPrint" do
        return map("type", "IRPrint", "value", propagate_ir_expr(get_key(ir_stmt, "value"), env))
    end

    when stype equals "IRIf" do
        create variable prop_cond as map with value propagate_ir_expr(get_key(ir_stmt, "cond"), env)
        create variable then_body as list with value get_key(ir_stmt, "then_body")
        create variable prop_then as list with value []
        create variable i as integer with value 0
        while i < length(then_body) do
            push(prop_then, propagate_ir_stmt(then_body[i], env))
            increase i by 1
        end
        create variable else_body as list with value get_key(ir_stmt, "else_body")
        create variable prop_else as list with value []
        set i to 0
        while i < length(else_body) do
            push(prop_else, propagate_ir_stmt(else_body[i], env))
            increase i by 1
        end
        return map("type", "IRIf", "cond", prop_cond, "then_body", prop_then, "else_body", prop_else)
    end

    when stype equals "IRWhile" do
        create variable prop_cond as map with value propagate_ir_expr(get_key(ir_stmt, "cond"), env)
        # Note: For loops, we clear the env because we can't track across iterations
        create variable empty_env as map with value map()
        create variable body as list with value get_key(ir_stmt, "body")
        create variable prop_body as list with value []
        create variable i as integer with value 0
        while i < length(body) do
            push(prop_body, propagate_ir_stmt(body[i], empty_env))
            increase i by 1
        end
        return map("type", "IRWhile", "cond", prop_cond, "body", prop_body)
    end

    when stype equals "IRRepeat" do
        create variable prop_count as map with value propagate_ir_expr(get_key(ir_stmt, "count"), env)
        # Clear env for loop body
        create variable empty_env as map with value map()
        create variable body as list with value get_key(ir_stmt, "body")
        create variable prop_body as list with value []
        create variable i as integer with value 0
        while i < length(body) do
            push(prop_body, propagate_ir_stmt(body[i], empty_env))
            increase i by 1
        end
        return map("type", "IRRepeat", "count", prop_count, "body", prop_body)
    end

    when stype equals "IRFunction" do
        # Fresh env for each function
        create variable func_env as map with value map()
        create variable body as list with value get_key(ir_stmt, "body")
        create variable prop_body as list with value []
        create variable i as integer with value 0
        while i < length(body) do
            push(prop_body, propagate_ir_stmt(body[i], func_env))
            increase i by 1
        end
        return map("type", "IRFunction", "name", get_key(ir_stmt, "name"), "ret_type", get_key(ir_stmt, "ret_type"), "body", prop_body)
    end

    return ir_stmt
end

function propagate_ir_module with ir_module as map returns map
    create variable env as map with value map()
    create variable prop_functions as list with value []
    create variable functions as list with value get_key(ir_module, "functions")
    create variable i as integer with value 0
    while i < length(functions) do
        push(prop_functions, propagate_ir_stmt(functions[i], env))
        increase i by 1
    end

    create variable prop_globals as list with value []
    create variable globals as list with value get_key(ir_module, "globals")
    set i to 0
    while i < length(globals) do
        push(prop_globals, propagate_ir_stmt(globals[i], env))
        increase i by 1
    end

    return map("functions", prop_functions, "globals", prop_globals)
end

# ============================================================
# DEAD CODE ELIMINATION (Phase 11)
# ============================================================

function collect_used_symbols_expr with expr as map and used_set as map returns nothing
    create variable etype as text with value get_key(expr, "type")

    when etype equals "IRSymbolRef" do
        create variable sym_id as integer with value get_key(expr, "symbol_id")
        set_key(used_set, sym_id, true)
    end

    when etype equals "IRBinaryOp" do
        collect_used_symbols_expr with get_key(expr, "left") and used_set
        collect_used_symbols_expr with get_key(expr, "right") and used_set
    end

    when etype equals "IRUnaryOp" do
        collect_used_symbols_expr with get_key(expr, "operand") and used_set
    end

    when etype equals "IRCall" do
        create variable args as list with value get_key(expr, "args")
        create variable i as integer with value 0
        while i < length(args) do
            collect_used_symbols_expr with args[i] and used_set
            increase i by 1
        end
    end
end

function collect_used_symbols_stmt with stmt as map and used_set as map returns nothing
    create variable stype as text with value get_key(stmt, "type")

    when stype equals "IRVarDecl" do
        collect_used_symbols_expr with get_key(stmt, "init") and used_set
    end

    when stype equals "IRAssign" do
        collect_used_symbols_expr with get_key(stmt, "value") and used_set
    end

    when stype equals "IRReturn" do
        collect_used_symbols_expr with get_key(stmt, "value") and used_set
    end

    when stype equals "IRPrint" do
        collect_used_symbols_expr with get_key(stmt, "value") and used_set
    end

    when stype equals "IRIf" do
        collect_used_symbols_expr with get_key(stmt, "cond") and used_set
        create variable then_body as list with value get_key(stmt, "then_body")
        create variable i as integer with value 0
        while i < length(then_body) do
            collect_used_symbols_stmt with then_body[i] and used_set
            increase i by 1
        end
        create variable else_body as list with value get_key(stmt, "else_body")
        set i to 0
        while i < length(else_body) do
            collect_used_symbols_stmt with else_body[i] and used_set
            increase i by 1
        end
    end

    when stype equals "IRWhile" do
        collect_used_symbols_expr with get_key(stmt, "cond") and used_set
        create variable body as list with value get_key(stmt, "body")
        create variable i as integer with value 0
        while i < length(body) do
            collect_used_symbols_stmt with body[i] and used_set
            increase i by 1
        end
    end

    when stype equals "IRRepeat" do
        collect_used_symbols_expr with get_key(stmt, "count") and used_set
        create variable body as list with value get_key(stmt, "body")
        create variable i as integer with value 0
        while i < length(body) do
            collect_used_symbols_stmt with body[i] and used_set
            increase i by 1
        end
    end

    when stype equals "IRFunction" do
        create variable body as list with value get_key(stmt, "body")
        create variable i as integer with value 0
        while i < length(body) do
            collect_used_symbols_stmt with body[i] and used_set
            increase i by 1
        end
    end
end

function is_pure_vardecl with stmt as map returns boolean
    # Check if variable declaration has no side effects
    # For now, all our var decls are pure (just initialization)
    # Future: check if init expression has function calls
    return true
end

function eliminate_dead_code_stmt with stmt as map and used_set as map returns map
    create variable stype as text with value get_key(stmt, "type")

    when stype equals "IRVarDecl" do
        create variable sym_id as integer with value get_key(stmt, "symbol_id")
        when not has_key(used_set, sym_id) and is_pure_vardecl(stmt) do
            # Return a marker for dead code (will be filtered out)
            return map("type", "IRDead")
        end
        return stmt
    end

    when stype equals "IRIf" do
        create variable then_body as list with value get_key(stmt, "then_body")
        create variable filtered_then as list with value []
        create variable i as integer with value 0
        while i < length(then_body) do
            create variable filtered_stmt as map with value eliminate_dead_code_stmt(then_body[i], used_set)
            when get_key(filtered_stmt, "type") != "IRDead" do
                push(filtered_then, filtered_stmt)
            end
            increase i by 1
        end

        create variable else_body as list with value get_key(stmt, "else_body")
        create variable filtered_else as list with value []
        set i to 0
        while i < length(else_body) do
            create variable filtered_stmt as map with value eliminate_dead_code_stmt(else_body[i], used_set)
            when get_key(filtered_stmt, "type") != "IRDead" do
                push(filtered_else, filtered_stmt)
            end
            increase i by 1
        end

        return map("type", "IRIf", "cond", get_key(stmt, "cond"), "then_body", filtered_then, "else_body", filtered_else)
    end

    when stype equals "IRWhile" do
        create variable body as list with value get_key(stmt, "body")
        create variable filtered_body as list with value []
        create variable i as integer with value 0
        while i < length(body) do
            create variable filtered_stmt as map with value eliminate_dead_code_stmt(body[i], used_set)
            when get_key(filtered_stmt, "type") != "IRDead" do
                push(filtered_body, filtered_stmt)
            end
            increase i by 1
        end
        return map("type", "IRWhile", "cond", get_key(stmt, "cond"), "body", filtered_body)
    end

    when stype equals "IRRepeat" do
        create variable body as list with value get_key(stmt, "body")
        create variable filtered_body as list with value []
        create variable i as integer with value 0
        while i < length(body) do
            create variable filtered_stmt as map with value eliminate_dead_code_stmt(body[i], used_set)
            when get_key(filtered_stmt, "type") != "IRDead" do
                push(filtered_body, filtered_stmt)
            end
            increase i by 1
        end
        return map("type", "IRRepeat", "count", get_key(stmt, "count"), "body", filtered_body)
    end

    when stype equals "IRFunction" do
        create variable body as list with value get_key(stmt, "body")
        create variable filtered_body as list with value []
        create variable i as integer with value 0
        while i < length(body) do
            create variable filtered_stmt as map with value eliminate_dead_code_stmt(body[i], used_set)
            when get_key(filtered_stmt, "type") != "IRDead" do
                push(filtered_body, filtered_stmt)
            end
            increase i by 1
        end
        return map("type", "IRFunction", "name", get_key(stmt, "name"), "ret_type", get_key(stmt, "ret_type"), "body", filtered_body)
    end

    return stmt
end

function eliminate_dead_code_module with ir_module as map returns map
    # First pass: collect all used symbols
    create variable used_set as map with value map()
    create variable functions as list with value get_key(ir_module, "functions")
    create variable i as integer with value 0
    while i < length(functions) do
        collect_used_symbols_stmt with functions[i] and used_set
        increase i by 1
    end

    create variable globals as list with value get_key(ir_module, "globals")
    set i to 0
    while i < length(globals) do
        collect_used_symbols_stmt with globals[i] and used_set
        increase i by 1
    end

    # Second pass: eliminate dead code
    create variable dce_functions as list with value []
    set i to 0
    while i < length(functions) do
        create variable filtered_stmt as map with value eliminate_dead_code_stmt(functions[i], used_set)
        when get_key(filtered_stmt, "type") != "IRDead" do
            push(dce_functions, filtered_stmt)
        end
        increase i by 1
    end

    create variable dce_globals as list with value []
    set i to 0
    while i < length(globals) do
        create variable filtered_stmt as map with value eliminate_dead_code_stmt(globals[i], used_set)
        when get_key(filtered_stmt, "type") != "IRDead" do
            push(dce_globals, filtered_stmt)
        end
        increase i by 1
    end

    return map("functions", dce_functions, "globals", dce_globals)
end

# ============================================================
# CONTROL FLOW GRAPH (Phase 12) - Basic Structure
# ============================================================

# CFG Structure:
# BasicBlock = {
#   id: integer,
#   statements: list,
#   successors: list of block ids,
#   predecessors: list of block ids
# }

function create_basic_block with block_id as integer returns map
    return map("id", block_id, "statements", [], "successors", [], "predecessors", [])
end

function add_stmt_to_block with block as map and stmt as map returns nothing
    create variable stmts as list with value get_key(block, "statements")
    push(stmts, stmt)
end

function add_edge with from_block as map and to_block_id as integer returns nothing
    create variable succs as list with value get_key(from_block, "successors")
    push(succs, to_block_id)
end

# Convert linear IR to CFG for a single function
function ir_to_cfg_function with ir_func as map and next_block_id as integer returns map
    create variable func_name as text with value get_key(ir_func, "name")
    create variable body as list with value get_key(ir_func, "body")
    create variable blocks as list with value []
    create variable current_block as map with value create_basic_block(next_block_id)
    set next_block_id to next_block_id + 1

    create variable i as integer with value 0
    while i < length(body) do
        create variable stmt as map with value body[i]
        create variable stype as text with value get_key(stmt, "type")

        when stype equals "IRIf" do
            # Finish current block with condition
            add_stmt_to_block with current_block and stmt
            push(blocks, current_block)

            # Create then block
            create variable then_block as map with value create_basic_block(next_block_id)
            set next_block_id to next_block_id + 1
            create variable then_body as list with value get_key(stmt, "then_body")
            create variable j as integer with value 0
            while j < length(then_body) do
                add_stmt_to_block with then_block and then_body[j]
                increase j by 1
            end
            push(blocks, then_block)

            # Create else block
            create variable else_block as map with value create_basic_block(next_block_id)
            set next_block_id to next_block_id + 1
            create variable else_body as list with value get_key(stmt, "else_body")
            set j to 0
            while j < length(else_body) do
                add_stmt_to_block with else_block and else_body[j]
                increase j by 1
            end
            push(blocks, else_block)

            # Create merge block for after if
            create variable merge_block as map with value create_basic_block(next_block_id)
            set next_block_id to next_block_id + 1

            # Add edges: current → then, current → else
            add_edge with current_block and get_key(then_block, "id")
            add_edge with current_block and get_key(else_block, "id")

            # Add edges: then → merge, else → merge
            add_edge with then_block and get_key(merge_block, "id")
            add_edge with else_block and get_key(merge_block, "id")

            # Continue with merge block
            set current_block to merge_block
        end

        when stype equals "IRWhile" do
            # Create condition block
            create variable cond_block as map with value create_basic_block(next_block_id)
            set next_block_id to next_block_id + 1
            add_stmt_to_block with cond_block and stmt
            push(blocks, current_block)

            # Create loop body block
            create variable loop_block as map with value create_basic_block(next_block_id)
            set next_block_id to next_block_id + 1
            create variable loop_body as list with value get_key(stmt, "body")
            create variable j as integer with value 0
            while j < length(loop_body) do
                add_stmt_to_block with loop_block and loop_body[j]
                increase j by 1
            end
            push(blocks, loop_block)

            # Create exit block
            create variable exit_block as map with value create_basic_block(next_block_id)
            set next_block_id to next_block_id + 1

            # Add edges: cond → loop (true), cond → exit (false)
            add_edge with cond_block and get_key(loop_block, "id")
            add_edge with cond_block and get_key(exit_block, "id")

            # Add edge: loop → cond (back edge)
            add_edge with loop_block and get_key(cond_block, "id")

            # Continue with exit block
            set current_block to exit_block
        end

        when stype equals "IRRepeat" do
            # Similar to while but with count
            add_stmt_to_block with current_block and stmt

            # Create loop body block
            create variable loop_block as map with value create_basic_block(next_block_id)
            set next_block_id to next_block_id + 1
            create variable loop_body as list with value get_key(stmt, "body")
            create variable j as integer with value 0
            while j < length(loop_body) do
                add_stmt_to_block with loop_block and loop_body[j]
                increase j by 1
            end
            push(blocks, loop_block)

            # Add edge for loop structure
            add_edge with current_block and get_key(loop_block, "id")

            # Continue with new block after loop
            push(blocks, current_block)
            set current_block to create_basic_block(next_block_id)
            set next_block_id to next_block_id + 1
        end

        # Other statements go to current block
        when stype != "IRIf" and stype != "IRWhile" and stype != "IRRepeat" do
            add_stmt_to_block with current_block and stmt
        end

        increase i by 1
    end

    # Don't forget the last block
    when length(get_key(current_block, "statements")) > 0 do
        push(blocks, current_block)
    end

    return map("name", func_name, "blocks", blocks, "next_block_id", next_block_id)
end

function ir_to_cfg_module with ir_module as map returns map
    create variable cfg_functions as list with value []
    create variable functions as list with value get_key(ir_module, "functions")
    create variable next_block_id as integer with value 0
    create variable i as integer with value 0

    while i < length(functions) do
        create variable cfg_func as map with value ir_to_cfg_function(functions[i], next_block_id)
        push(cfg_functions, cfg_func)
        set next_block_id to get_key(cfg_func, "next_block_id")
        increase i by 1
    end

    return map("type", "CFG", "functions", cfg_functions)
end

function dump_cfg_block with block as map returns text
    create variable out as text with value ""
    set out to out attach "Block " attach get_key(block, "id") attach ":\n"

    create variable stmts as list with value get_key(block, "statements")
    create variable i as integer with value 0
    while i < length(stmts) do
        set out to out attach "  " attach get_key(stmts[i], "type") attach "\n"
        increase i by 1
    end

    create variable succs as list with value get_key(block, "successors")
    when length(succs) > 0 do
        set out to out attach "  → successors: " attach succs attach "\n"
    end

    return out
end

function dump_cfg with cfg_module as map returns text
    create variable out as text with value "=== CFG DUMP ===\n"
    create variable funcs as list with value get_key(cfg_module, "functions")
    create variable i as integer with value 0
    while i < length(funcs) do
        set out to out attach "Function: " attach get_key(funcs[i], "name") attach "\n"
        create variable blocks as list with value get_key(funcs[i], "blocks")
        create variable j as integer with value 0
        while j < length(blocks) do
            set out to out attach dump_cfg_block(blocks[j]) attach "\n"
            increase j by 1
        end
        increase i by 1
    end
    return out
end

# ============================================================
# TYPE CHECKING (Phase 10)
# ============================================================

function type_of_expr with expr as map returns text
    create variable etype as text with value get_key(expr, "type")
    when etype equals "IRLiteral" do return get_key(expr, "literal_type") end
    when etype equals "IRSymbolRef" do return get_key(expr, "data_type") end
    when etype equals "IRBinaryOp" do return get_key(expr, "data_type") end
    when etype equals "IRUnaryOp" do return "boolean" end
    when etype equals "IRCall" do return get_key(expr, "data_type") end
    return "unknown"
end

function type_check_expr with expr as map and context as text returns nothing
    create variable etype as text with value get_key(expr, "type")

    when etype equals "IRBinaryOp" do
        create variable op as text with value get_key(expr, "op")
        create variable left as map with value get_key(expr, "left")
        create variable right as map with value get_key(expr, "right")

        # Type check operands first (recursively)
        type_check_expr with left and "operand"
        type_check_expr with right and "operand"

        # Check type compatibility
        create variable left_type as text with value type_of_expr(left)
        create variable right_type as text with value type_of_expr(right)

        # Only integer operations supported for now
        when left_type != "integer" do
            add_error with "Type error: left operand of " attach op attach " has type " attach left_type attach " (expected integer)" and make_location(1, 1)
        end
        when right_type != "integer" do
            add_error with "Type error: right operand of " attach op attach " has type " attach right_type attach " (expected integer)" and make_location(1, 1)
        end
    end

    when etype equals "IRUnaryOp" do
        type_check_expr with get_key(expr, "operand") and "operand"
    end

    when etype equals "IRCall" do
        # Type check all arguments
        create variable args as list with value get_key(expr, "args")
        create variable i as integer with value 0
        while i < length(args) do
            type_check_expr with args[i] and "argument"
            increase i by 1
        end
    end
end

function type_check_stmt with stmt as map returns nothing
    create variable stype as text with value get_key(stmt, "type")

    when stype equals "IRVarDecl" do
        type_check_expr with get_key(stmt, "init") and "initialization"

        # Check if init type matches var type
        create variable var_type as text with value get_key(stmt, "var_type")
        create variable init_type as text with value type_of_expr(get_key(stmt, "init"))
        when init_type != var_type and init_type != "unknown" do
            add_error with "Type error: cannot assign " attach init_type attach " to variable of type " attach var_type and make_location(1, 1)
        end
    end

    when stype equals "IRAssign" do
        type_check_expr with get_key(stmt, "value") and "assignment"
    end

    when stype equals "IRReturn" do
        type_check_expr with get_key(stmt, "value") and "return"
    end

    when stype equals "IRPrint" do
        type_check_expr with get_key(stmt, "value") and "print"
    end

    when stype equals "IRIf" do
        type_check_expr with get_key(stmt, "cond") and "condition"
        create variable then_body as list with value get_key(stmt, "then_body")
        create variable i as integer with value 0
        while i < length(then_body) do
            type_check_stmt with then_body[i]
            increase i by 1
        end
        create variable else_body as list with value get_key(stmt, "else_body")
        set i to 0
        while i < length(else_body) do
            type_check_stmt with else_body[i]
            increase i by 1
        end
    end

    when stype equals "IRWhile" do
        type_check_expr with get_key(stmt, "cond") and "condition"
        create variable body as list with value get_key(stmt, "body")
        create variable i as integer with value 0
        while i < length(body) do
            type_check_stmt with body[i]
            increase i by 1
        end
    end

    when stype equals "IRRepeat" do
        type_check_expr with get_key(stmt, "count") and "count"
        create variable body as list with value get_key(stmt, "body")
        create variable i as integer with value 0
        while i < length(body) do
            type_check_stmt with body[i]
            increase i by 1
        end
    end

    when stype equals "IRFunction" do
        create variable body as list with value get_key(stmt, "body")
        create variable i as integer with value 0
        while i < length(body) do
            type_check_stmt with body[i]
            increase i by 1
        end
    end
end

function type_check_ir with ir_module as map returns nothing
    create variable functions as list with value get_key(ir_module, "functions")
    create variable i as integer with value 0
    while i < length(functions) do
        type_check_stmt with functions[i]
        increase i by 1
    end

    create variable globals as list with value get_key(ir_module, "globals")
    set i to 0
    while i < length(globals) do
        type_check_stmt with globals[i]
        increase i by 1
    end
end

# ============================================================
# CONSTANT FOLDING OPTIMIZATION (Phase 9.5)
# ============================================================

function fold_ir_expr with ir_expr as map returns map
    create variable etype as text with value get_key(ir_expr, "type")

    when etype equals "IRBinaryOp" do
        # Recursively fold operands first
        create variable left_folded as map with value fold_ir_expr(get_key(ir_expr, "left"))
        create variable right_folded as map with value fold_ir_expr(get_key(ir_expr, "right"))

        create variable left_type as text with value get_key(left_folded, "type")
        create variable right_type as text with value get_key(right_folded, "type")

        # Only fold if both operands are integer literals
        when left_type equals "IRLiteral" and right_type equals "IRLiteral" do
            create variable left_lit_type as text with value get_key(left_folded, "literal_type")
            create variable right_lit_type as text with value get_key(right_folded, "literal_type")

            # Only fold integer operations
            when left_lit_type equals "integer" and right_lit_type equals "integer" do
                create variable left_val as integer with value get_key(left_folded, "value")
                create variable right_val as integer with value get_key(right_folded, "value")
                create variable op as text with value get_key(ir_expr, "op")
                create variable result as integer with value 0

                when op equals "+" do set result to left_val + right_val end
                when op equals "-" do set result to left_val - right_val end
                when op equals "*" do set result to left_val * right_val end
                when op equals "/" do
                    when right_val equals 0 do
                        # Division by zero - don't fold, keep original
                        return map("type", "IRBinaryOp", "op", op, "left", left_folded, "right", right_folded)
                    end
                    set result to left_val / right_val
                end

                return map("type", "IRLiteral", "literal_type", "integer", "value", result, "data_type", "integer")
            end
        end

        # Algebraic simplification rules (Phase 9.6)
        # These are safe because they don't change semantics for any operand type
        create variable op as text with value get_key(ir_expr, "op")

        # x + 0 → x, 0 + x → x
        when op equals "+" do
            create variable left_is_zero as boolean with value left_type equals "IRLiteral" and get_key(left_folded, "literal_type") equals "integer" and get_key(left_folded, "value") equals 0
            create variable right_is_zero as boolean with value right_type equals "IRLiteral" and get_key(right_folded, "literal_type") equals "integer" and get_key(right_folded, "value") equals 0
            when left_is_zero do return right_folded end
            when right_is_zero do return left_folded end
        end

        # x - 0 → x
        when op equals "-" do
            create variable right_is_zero as boolean with value right_type equals "IRLiteral" and get_key(right_folded, "literal_type") equals "integer" and get_key(right_folded, "value") equals 0
            when right_is_zero do return left_folded end
        end

        # x * 1 → x, 1 * x → x
        when op equals "*" do
            create variable left_is_one as boolean with value left_type equals "IRLiteral" and get_key(left_folded, "literal_type") equals "integer" and get_key(left_folded, "value") equals 1
            create variable right_is_one as boolean with value right_type equals "IRLiteral" and get_key(right_folded, "literal_type") equals "integer" and get_key(right_folded, "value") equals 1
            when left_is_one do return right_folded end
            when right_is_one do return left_folded end
        end

        # x * 0 → 0, 0 * x → 0 (only if x has no side effects)
        # Since we only fold literals and variables (no function calls in this IR),
        # this is safe
        when op equals "*" do
            create variable left_is_zero as boolean with value left_type equals "IRLiteral" and get_key(left_folded, "literal_type") equals "integer" and get_key(left_folded, "value") equals 0
            create variable right_is_zero as boolean with value right_type equals "IRLiteral" and get_key(right_folded, "literal_type") equals "integer" and get_key(right_folded, "value") equals 0
            when left_is_zero do return left_folded end
            when right_is_zero do return right_folded end
        end

        # Return with folded operands (even if we couldn't fold the whole expression)
        return map("type", "IRBinaryOp", "op", get_key(ir_expr, "op"), "left", left_folded, "right", right_folded)
    end

    when etype equals "IRUnaryOp" do
        return map("type", "IRUnaryOp", "op", get_key(ir_expr, "op"), "operand", fold_ir_expr(get_key(ir_expr, "operand")))
    end

    # Non-folding expressions return as-is
    return ir_expr
end

function fold_ir_stmt with ir_stmt as map returns map
    create variable stype as text with value get_key(ir_stmt, "type")

    when stype equals "IRVarDecl" do
        return map("type", "IRVarDecl", "name", get_key(ir_stmt, "name"), "symbol_id", get_key(ir_stmt, "symbol_id"), "var_type", get_key(ir_stmt, "var_type"), "init", fold_ir_expr(get_key(ir_stmt, "init")))
    end

    when stype equals "IRAssign" do
        return map("type", "IRAssign", "name", get_key(ir_stmt, "name"), "symbol_id", get_key(ir_stmt, "symbol_id"), "value", fold_ir_expr(get_key(ir_stmt, "value")))
    end

    when stype equals "IRReturn" do
        return map("type", "IRReturn", "value", fold_ir_expr(get_key(ir_stmt, "value")))
    end

    when stype equals "IRPrint" do
        return map("type", "IRPrint", "value", fold_ir_expr(get_key(ir_stmt, "value")))
    end

    when stype equals "IRIf" do
        create variable folded_then as list with value []
        create variable then_body as list with value get_key(ir_stmt, "then_body")
        create variable i as integer with value 0
        while i < length(then_body) do
            push(folded_then, fold_ir_stmt(then_body[i]))
            increase i by 1
        end

        create variable folded_else as list with value []
        create variable else_body as list with value get_key(ir_stmt, "else_body")
        set i to 0
        while i < length(else_body) do
            push(folded_else, fold_ir_stmt(else_body[i]))
            increase i by 1
        end

        return map("type", "IRIf", "cond", fold_ir_expr(get_key(ir_stmt, "cond")), "then_body", folded_then, "else_body", folded_else)
    end

    when stype equals "IRWhile" do
        create variable folded_body as list with value []
        create variable body as list with value get_key(ir_stmt, "body")
        create variable i as integer with value 0
        while i < length(body) do
            push(folded_body, fold_ir_stmt(body[i]))
            increase i by 1
        end

        return map("type", "IRWhile", "cond", fold_ir_expr(get_key(ir_stmt, "cond")), "body", folded_body)
    end

    when stype equals "IRRepeat" do
        create variable folded_body as list with value []
        create variable body as list with value get_key(ir_stmt, "body")
        create variable i as integer with value 0
        while i < length(body) do
            push(folded_body, fold_ir_stmt(body[i]))
            increase i by 1
        end

        return map("type", "IRRepeat", "count", fold_ir_expr(get_key(ir_stmt, "count")), "body", folded_body)
    end

    when stype equals "IRFunction" do
        create variable folded_body as list with value []
        create variable body as list with value get_key(ir_stmt, "body")
        create variable i as integer with value 0
        while i < length(body) do
            push(folded_body, fold_ir_stmt(body[i]))
            increase i by 1
        end

        return map("type", "IRFunction", "name", get_key(ir_stmt, "name"), "ret_type", get_key(ir_stmt, "ret_type"), "body", folded_body)
    end

    return ir_stmt
end

function optimize_ir_module with ir_module as map returns map
    create variable optimized_functions as list with value []
    create variable functions as list with value get_key(ir_module, "functions")
    create variable i as integer with value 0
    while i < length(functions) do
        push(optimized_functions, fold_ir_stmt(functions[i]))
        increase i by 1
    end

    create variable optimized_globals as list with value []
    create variable globals as list with value get_key(ir_module, "globals")
    set i to 0
    while i < length(globals) do
        push(optimized_globals, fold_ir_stmt(globals[i]))
        increase i by 1
    end

    return map("functions", optimized_functions, "globals", optimized_globals)
end

# ============================================================
# IR DEBUG UTILITIES (Phase 9.4)
# ============================================================

function dump_ir_expr with ir_expr as map and indent as text returns text
    create variable etype as text with value get_key(ir_expr, "type")
    create variable out as text with value indent
    when etype equals "IRLiteral" do
        set out to out attach "LITERAL[" attach get_key(ir_expr, "literal_type") attach "] = " attach get_key(ir_expr, "value")
    end
    when etype equals "IRVariable" do
        set out to out attach "VAR[" attach get_key(ir_expr, "name") attach "]"
    end
    when etype equals "IRSymbolRef" do
        set out to out attach "SYM[" attach get_key(ir_expr, "symbol_id") attach ":" attach get_key(ir_expr, "nm") attach "]"
    end
    when etype equals "IRBinaryOp" do
        set out to out attach "BIN[" attach get_key(ir_expr, "op") attach "]\n"
        set out to out attach dump_ir_expr(get_key(ir_expr, "left"), indent attach "  ") attach "\n"
        set out to out attach dump_ir_expr(get_key(ir_expr, "right"), indent attach "  ")
    end
    return out
end

function dump_ir_stmt with ir_stmt as map and indent as text returns text
    create variable stype as text with value get_key(ir_stmt, "type")
    create variable out as text with value indent
    when stype equals "IRVarDecl" do
        set out to out attach "VAR_DECL[" attach get_key(ir_stmt, "symbol_id") attach " : " attach get_key(ir_stmt, "var_type") attach "]\n"
        set out to out attach dump_ir_expr(get_key(ir_stmt, "init"), indent attach "  ")
    end
    when stype equals "IRAssign" do
        set out to out attach "ASSIGN[" attach get_key(ir_stmt, "symbol_id") attach "] = \n"
        set out to out attach dump_ir_expr(get_key(ir_stmt, "value"), indent attach "  ")
    end
    when stype equals "IRPrint" do
        set out to out attach "PRINT\n"
        set out to out attach dump_ir_expr(get_key(ir_stmt, "value"), indent attach "  ")
    end
    when stype equals "IRReturn" do
        set out to out attach "RETURN\n"
        set out to out attach dump_ir_expr(get_key(ir_stmt, "value"), indent attach "  ")
    end
    when stype equals "IRIf" do
        set out to out attach "IF\n"
        set out to out attach dump_ir_expr(get_key(ir_stmt, "cond"), indent attach "  ") attach "\n"
        set out to out attach indent attach "THEN:\n"
        create variable then_body as list with value get_key(ir_stmt, "then_body")
        create variable i as integer with value 0
        while i < length(then_body) do
            set out to out attach dump_ir_stmt(then_body[i], indent attach "    ") attach "\n"
            increase i by 1
        end
        set out to out attach indent attach "ELSE:\n"
        create variable else_body as list with value get_key(ir_stmt, "else_body")
        set i to 0
        while i < length(else_body) do
            set out to out attach dump_ir_stmt(else_body[i], indent attach "    ") attach "\n"
            increase i by 1
        end
    end
    when stype equals "IRFunction" do
        set out to out attach "FUNC[" attach get_key(ir_stmt, "name") attach " : " attach get_key(ir_stmt, "ret_type") attach "]\n"
        create variable body as list with value get_key(ir_stmt, "body")
        create variable i as integer with value 0
        while i < length(body) do
            set out to out attach dump_ir_stmt(body[i], indent attach "  ") attach "\n"
            increase i by 1
        end
    end
    return out
end

function dump_ir_module with ir_module as map returns text
    create variable out as text with value "=== IR DUMP ===\n"
    create variable functions as list with value get_key(ir_module, "functions")
    create variable i as integer with value 0
    while i < length(functions) do
        set out to out attach dump_ir_stmt(functions[i], "") attach "\n"
        increase i by 1
    end
    set out to out attach "=== GLOBALS ===\n"
    create variable globals as list with value get_key(ir_module, "globals")
    set i to 0
    while i < length(globals) do
        set out to out attach dump_ir_stmt(globals[i], "") attach "\n"
        increase i by 1
    end
    return out
end

# ============================================================
# IR CONVERSION (updated for SymbolRef)
# ============================================================

function ast_to_ir_expr(ast_node) returns map
    create variable kind as text with value get_key(ast_node, "kind")
    when kind equals "Literal" do
        return map("type", "IRLiteral", "literal_type", get_key(ast_node, "type"), "value", get_key(ast_node, "value"), "data_type", get_key(ast_node, "type"))
    end
    when kind equals "Identifier" do
        return map("type", "IRVariable", "name", get_key(ast_node, "name"))
    end
    when kind equals "SymbolRef" do
        create variable sym_id as integer with value get_key(ast_node, "symbol_id")
        create variable sym as map with value get_symbol(sym_id)
        return map("type", "IRSymbolRef", "symbol_id", sym_id, "nm", get_key(sym, "nm"), "data_type", get_key(sym, "dt"))
    end
    when kind equals "BinaryExpr" do
        create variable op as text with value get_key(ast_node, "operator")
        create variable left as map with value ast_to_ir_expr(get_key(ast_node, "left"))
        create variable right as map with value ast_to_ir_expr(get_key(ast_node, "right"))
        when op equals "==" do set op to "EQ" end
        when op equals ">" do set op to "GT" end
        when op equals "<" do set op to "LT" end
        when op equals ">=" do set op to "GTE" end
        when op equals "<=" do set op to "LTE" end
        when op equals "+" do set op to "ADD" end
        when op equals "-" do set op to "SUB" end
        when op equals "*" do set op to "MUL" end
        when op equals "/" do set op to "DIV" end
        when op equals "%" do set op to "MOD" end
        when op equals "&&" do set op to "AND" end
        when op equals "||" do set op to "OR" end
        # For arithmetic ops, result type is same as operand type (assumed same)
        # For comparison ops, result type is boolean (use integer for now)
        create variable result_type as text with value "integer"
        when op equals "EQ" or op equals "GT" or op equals "LT" or op equals "GTE" or op equals "LTE" do
            set result_type to "boolean"
        end
        return map("type", "IRBinaryOp", "op", op, "left", left, "right", right, "data_type", result_type)
    end
    when kind equals "UnaryExpr" do
        create variable op as text with value get_key(ast_node, "operator")
        create variable operand as map with value ast_to_ir_expr(get_key(ast_node, "operand"))
        when op equals "!" do set op to "NOT" end
        return map("type", "IRUnaryOp", "op", op, "operand", operand)
    end
    when kind equals "FunctionCallExpr" do
        create variable func_name as text with value get_key(ast_node, "name")
        create variable args as list with value []
        create variable ast_args as list with value get_key(ast_node, "arguments")
        create variable i as integer with value 0
        while i < length(ast_args) do
            push(args, ast_to_ir_expr(ast_args[i]))
            increase i by 1
        end
        # Get function return type from function table
        create variable func_ret_type as text with value "nothing"
        when has_key(function_table, func_name) do
            set func_ret_type to get_key(function_table[func_name], "ret_type")
        end
        return map("type", "IRCall", "func", func_name, "args", args, "data_type", func_ret_type)
    end
    return map("type", "IRLiteral", "literal_type", "nothing", "value", nothing)
end

function ast_to_ir_stmt(ast_stmt) returns map
    create variable kind as text with value get_key(ast_stmt, "kind")
    when kind equals "VariableDecl" do
        create variable var_name as text with value get_key(ast_stmt, "nm")
        create variable var_type as text with value get_key(ast_stmt, "tp")
        create variable init_val as map with value get_key(ast_stmt, "init")
        when init_val equals nothing do
            return map("type", "IRVarDecl", "name", var_name, "var_type", var_type, "init", map("type", "IRLiteral", "literal_type", "nothing", "value", nothing))
        end
        create variable ir_init as map with value ast_to_ir_expr(init_val)
        return map("type", "IRVarDecl", "name", var_name, "var_type", var_type, "init", ir_init)
    end
    when kind equals "AssignVar" do
        create variable var_name as text with value get_key(ast_stmt, "nm")
        create variable sym_id as integer with value get_key(ast_stmt, "sym_id")
        create variable ir_val as map with value ast_to_ir_expr(get_key(ast_stmt, "val"))
        return map("type", "IRAssign", "name", var_name, "symbol_id", sym_id, "value", ir_val)
    end
    when kind equals "PrintStmt" do
        create variable exprs as list with value get_key(ast_stmt, "expressions")
        create variable ir_val as map with value ast_to_ir_expr(exprs[0])
        return map("type", "IRPrint", "value", ir_val)
    end
    when kind equals "ReturnStmt" do
        create variable ret_val as map with value get_key(ast_stmt, "val")
        when ret_val equals nothing do
            return map("type", "IRReturn", "value", map("type", "IRLiteral", "literal_type", "nothing", "value", nothing))
        end
        create variable ir_val as map with value ast_to_ir_expr(ret_val)
        return map("type", "IRReturn", "value", ir_val)
    end
    when kind equals "When" do
        create variable branches as list with value get_key(ast_stmt, "branches")
        create variable first_branch as map with value branches[0]
        create variable ir_cond as map with value ast_to_ir_expr(get_key(first_branch, "cond"))
        create variable then_body as list with value []
        create variable ast_then as list with value get_key(first_branch, "body")
        create variable i as integer with value 0
        while i < length(ast_then) do
            push(then_body, ast_to_ir_stmt(ast_then[i]))
            increase i by 1
        end
        create variable else_body as list with value []
        create variable ast_else as list with value get_key(ast_stmt, "otherwise")
        when ast_else != nothing do
            set i to 0
            while i < length(ast_else) do
                push(else_body, ast_to_ir_stmt(ast_else[i]))
                increase i by 1
            end
        end
        return map("type", "IRIf", "cond", ir_cond, "then_body", then_body, "else_body", else_body)
    end
    when kind equals "While" do
        create variable ir_cond as map with value ast_to_ir_expr(get_key(ast_stmt, "cond"))
        create variable body as list with value []
        create variable ast_body as list with value get_key(ast_stmt, "body")
        create variable i as integer with value 0
        while i < length(ast_body) do
            push(body, ast_to_ir_stmt(ast_body[i]))
            increase i by 1
        end
        return map("type", "IRWhile", "cond", ir_cond, "body", body)
    end
    when kind equals "Repeat" do
        create variable ir_count as map with value ast_to_ir_expr(get_key(ast_stmt, "cnt"))
        create variable body as list with value []
        create variable ast_body as list with value get_key(ast_stmt, "body")
        create variable i as integer with value 0
        while i < length(ast_body) do
            push(body, ast_to_ir_stmt(ast_body[i]))
            increase i by 1
        end
        return map("type", "IRRepeat", "count", ir_count, "body", body)
    end
    when kind equals "Increase" do
        create variable target as map with value get_key(ast_stmt, "target")
        create variable amount as map with value get_key(ast_stmt, "amount")
        create variable var_name as text with value ""
        when get_key(target, "kind") equals "Identifier" do
            set var_name to get_key(target, "name")
        end
        create variable ir_amount as map with value ast_to_ir_expr(amount)
        return map("type", "IRAssign", "name", var_name, "value", map("type", "IRBinaryOp", "op", "ADD", "left", map("type", "IRVariable", "name", var_name), "right", ir_amount))
    end
    when kind equals "FunctionDecl" do
        create variable func_name as text with value get_key(ast_stmt, "nm")
        create variable params as list with value []
        create variable ast_params as list with value get_key(ast_stmt, "parameters")
        create variable i as integer with value 0
        while i < length(ast_params) do
            create variable p as map with value ast_params[i]
            push(params, map("name", get_key(p, "name"), "param_type", get_key(p, "typeName")))
            increase i by 1
        end
        create variable body as list with value []
        create variable ast_body as list with value get_key(ast_stmt, "body")
        set i to 0
        while i < length(ast_body) do
            push(body, ast_to_ir_stmt(ast_body[i]))
            increase i by 1
        end
        return map("type", "IRFunction", "name", func_name, "params", params, "ret_type", get_key(ast_stmt, "returnType"), "body", body)
    end
    when kind equals "ExprStmt" do
        # Expression statement (function call without assignment)
        create variable expr as map with value get_key(ast_stmt, "expression")
        when get_key(expr, "kind") equals "FunctionCallExpr" do
            return ast_to_ir_stmt(map("kind", "FunctionCallStmt", "expression", expr))
        end
    end
    return map("type", "IRBlock", "stmts", [])
end

function ast_to_ir_program(ast) returns map
    create variable functions as list with value []
    create variable globals as list with value []
    create variable stmts as list with value get_key(ast, "statements")
    create variable i as integer with value 0
    while i < length(stmts) do
        create variable stmt as map with value stmts[i]
        create variable ir_stmt as map with value ast_to_ir_stmt(stmt)
        when get_key(ir_stmt, "type") equals "IRFunction" do
            push(functions, ir_stmt)
        otherwise do
            push(globals, ir_stmt)
        end
        increase i by 1
    end
    return map("type", "IRModule", "functions", functions, "globals", globals)
end

# ============================================================
# STAGE 4: IR → C CODE GENERATOR
# ============================================================

function ir_type_to_c(ir_type) returns text
    when ir_type equals "integer" do return "long long" end
    when ir_type equals "float" do return "double" end
    when ir_type equals "boolean" do return "bool" end
    when ir_type equals "text" do return "char*" end
    when ir_type equals "nothing" do return "void" end
    return ir_type
end

function gen_c_indent(level) returns text
    create variable out as text with value ""
    create variable i as integer with value 0
    while i < level do
        set out to out attach "    "
        increase i by 1
    end
    return out
end

function ir_to_c_expr(ir_expr) returns text
    create variable etype as text with value get_key(ir_expr, "type")
    when etype equals "IRLiteral" do
        create variable lit_type as text with value get_key(ir_expr, "literal_type")
        create variable lit_val as anything with value get_key(ir_expr, "value")
        when lit_type equals "text" do return "\"" attach lit_val attach "\"" end
        when lit_type equals "boolean" do
            when lit_val equals true do return "true" end
            return "false"
        end
        return to_text(lit_val)
    end
    when etype equals "IRVariable" do
        return get_key(ir_expr, "name")
    end
    when etype equals "IRSymRef" do
        create variable sym_id as integer with value get_key(ir_expr, "symbol_id")
        return symbol_id_to_c_name(sym_id)
    end
    when etype equals "IRBinaryOp" do
        create variable left as text with value ir_to_c_expr(get_key(ir_expr, "left"))
        create variable right as text with value ir_to_c_expr(get_key(ir_expr, "right"))
        create variable op as text with value get_key(ir_expr, "op")
        when op equals "EQ" do set op to "==" end
        when op equals "GT" do set op to ">" end
        when op equals "LT" do set op to "<" end
        when op equals "GTE" do set op to ">=" end
        when op equals "LTE" do set op to "<=" end
        when op equals "ADD" do set op to "+" end
        when op equals "SUB" do set op to "-" end
        when op equals "MUL" do set op to "*" end
        when op equals "DIV" do set op to "/" end
        when op equals "MOD" do set op to "%" end
        when op equals "AND" do set op to "&&" end
        when op equals "OR" do set op to "||" end
        return "(" attach left attach " " attach op attach " " attach right attach ")"
    end
    when etype equals "IRUnaryOp" do
        create variable operand as text with value ir_to_c_expr(get_key(ir_expr, "operand"))
        create variable op as text with value get_key(ir_expr, "op")
        when op equals "NOT" do set op to "!" end
        when op equals "MINUS" do set op to "-" end
        return "(" attach op attach operand attach ")"
    end
    when etype equals "IRCall" do
        create variable func_name as text with value get_key(ir_expr, "func")
        create variable args as list with value get_key(ir_expr, "args")

        # Check if this is a built-in stdlib function
        when func_name equals "len" do
            create variable arg_code as text with value ir_to_c_expr(args[0])
            return "strlen(" attach arg_code attach ")"
        end
        when func_name equals "to_string" do
            create variable arg_code as text with value ir_to_c_expr(args[0])
            # For simplicity, use sprintf or to_text
            return "to_text(" attach arg_code attach ")"
        end
        when func_name equals "substr" do
            create variable str_arg as text with value ir_to_c_expr(args[0])
            create variable start_arg as text with value ir_to_c_expr(args[1])
            create variable end_arg as text with value ir_to_c_expr(args[2])
            # Would need a helper function in C runtime
            return "iozen_substr(" attach str_arg attach ", " attach start_arg attach ", " attach end_arg attach ")"
        end
        when func_name equals "contains" do
            create variable str_arg as text with value ir_to_c_expr(args[0])
            create variable sub_arg as text with value ir_to_c_expr(args[1])
            # Would need a helper function in C runtime
            return "iozen_contains(" attach str_arg attach ", " attach sub_arg attach ")"
        end

        # Regular function call
        create variable out as text with value func_name attach "("
        create variable i as integer with value 0
        while i < length(args) do
            set out to out attach ir_to_c_expr(args[i])
            when i < length(args) - 1 do set out to out attach ", " end
            increase i by 1
        end
        return out attach ")"
    end
    return "0"
end

function ir_to_c_stmt(ir_stmt, indent) returns text
    create variable stype as text with value get_key(ir_stmt, "type")
    create variable ind as text with value gen_c_indent(indent)
    when stype equals "IRVarDecl" do
        create variable sym_id as integer with value get_key(ir_stmt, "symbol_id")
        create variable c_name as text with value symbol_id_to_c_name(sym_id)
        create variable var_type as text with value ir_type_to_c(get_key(ir_stmt, "var_type"))
        create variable init as map with value get_key(ir_stmt, "init")
        return ind attach var_type attach " " attach c_name attach " = " attach ir_to_c_expr(init) attach ";\n"
    end
    when stype equals "IRAssign" do
        create variable sym_id as integer with value get_key(ir_stmt, "symbol_id")
        create variable c_name as text with value symbol_id_to_c_name(sym_id)
        create variable var_value as map with value get_key(ir_stmt, "value")
        return ind attach c_name attach " = " attach ir_to_c_expr(var_value) attach ";\n"
    end
    when stype equals "IRPrint" do
        create variable print_val as map with value get_key(ir_stmt, "value")
        create variable expr_code as text with value ir_to_c_expr(print_val)
        create variable lit_type as text with value get_key(get_key(ir_stmt, "value"), "literal_type")
        when lit_type equals "text" do
            return ind attach "printf(\"%s\\n\", " attach expr_code attach ");\n"
        end
        return ind attach "printf(\"%lld\\n\", " attach expr_code attach ");\n"
    end
    when stype equals "IRReturn" do
        create variable ret_value as map with value get_key(ir_stmt, "value")
        return ind attach "return " attach ir_to_c_expr(ret_value) attach ";\n"
    end
    when stype equals "IRIf" do
        create variable cond as text with value ir_to_c_expr(get_key(ir_stmt, "cond"))
        create variable out as text with value ind attach "if (" attach cond attach ") {\n"
        create variable then_body as list with value get_key(ir_stmt, "then_body")
        create variable i as integer with value 0
        while i < length(then_body) do
            set out to out attach ir_to_c_stmt(then_body[i], indent + 1)
            increase i by 1
        end
        create variable else_body as list with value get_key(ir_stmt, "else_body")
        when length(else_body) > 0 do
            set out to out attach ind attach "} else {\n"
            set i to 0
            while i < length(else_body) do
                set out to out attach ir_to_c_stmt(else_body[i], indent + 1)
                increase i by 1
            end
        end
        return out attach ind attach "}\n"
    end
    when stype equals "IRWhile" do
        create variable cond as text with value ir_to_c_expr(get_key(ir_stmt, "cond"))
        create variable out as text with value ind attach "while (" attach cond attach ") {\n"
        create variable body as list with value get_key(ir_stmt, "body")
        create variable i as integer with value 0
        while i < length(body) do
            set out to out attach ir_to_c_stmt(body[i], indent + 1)
            increase i by 1
        end
        return out attach ind attach "}\n"
    end
    when stype equals "IRRepeat" do
        create variable count as text with value ir_to_c_expr(get_key(ir_stmt, "count"))
        create variable out as text with value ind attach "for (long long _i = 0; _i < " attach count attach "; _i++) {\n"
        create variable body as list with value get_key(ir_stmt, "body")
        create variable i as integer with value 0
        while i < length(body) do
            set out to out attach ir_to_c_stmt(body[i], indent + 1)
            increase i by 1
        end
        return out attach ind attach "}\n"
    end
    return ""
end

function ir_function_to_c(ir_func) returns text
    create variable name as text with value get_key(ir_func, "name")
    create variable ret_type as text with value ir_type_to_c(get_key(ir_func, "ret_type"))
    create variable params as list with value get_key(ir_func, "params")
    create variable param_str as text with value ""
    create variable i as integer with value 0
    while i < length(params) do
        create variable p as map with value params[i]
        set param_str to param_str attach ir_type_to_c(get_key(p, "param_type")) attach " " attach get_key(p, "name")
        when i < length(params) - 1 do set param_str to param_str attach ", " end
        increase i by 1
    end
    when length(params) equals 0 do set param_str to "void" end
    create variable out as text with value ret_type attach " " attach name attach "(" attach param_str attach ") {\n"
    create variable body as list with value get_key(ir_func, "body")
    set i to 0
    while i < length(body) do
        set out to out attach ir_to_c_stmt(body[i], 1)
        increase i by 1
    end
    return out attach "}\n\n"
end

function ir_module_to_c(ir_mod) returns text
    create variable out as text with value "/* Generated by IOZENC IR */\n\n"
    set out to out attach "#include <stdio.h>\n"
    set out to out attach "#include <stdbool.h>\n"
    set out to out attach "#include <string.h>\n\n"

    # C helper functions for stdlib
    set out to out attach "/* IOZEN Standard Library Helpers */\n"
    set out to out attach "char* iozen_substr(char* s, int start, int end) {\n"
    set out to out attach "    static char buf[1024];\n"
    set out to out attach "    int j = 0;\n"
    set out to out attach "    for (int i = start; i < end && s[i]; i++) {\n"
    set out to out attach "        buf[j++] = s[i];\n"
    set out to out attach "    }\n"
    set out to out attach "    buf[j] = '\\0';\n"
    set out to out attach "    return buf;\n"
    set out to out attach "}\n\n"
    set out to out attach "bool iozen_contains(char* s, char* sub) {\n"
    set out to out attach "    return strstr(s, sub) != NULL;\n"
    set out to out attach "}\n\n"
    create variable functions as list with value get_key(ir_mod, "functions")
    create variable i as integer with value 0
    while i < length(functions) do
        set out to out attach ir_function_to_c(functions[i])
        increase i by 1
    end
    set out to out attach "int main() {\n"
    create variable globals as list with value get_key(ir_mod, "globals")
    set i to 0
    while i < length(globals) do
        set out to out attach ir_to_c_stmt(globals[i], 1)
        increase i by 1
    end
    set out to out attach "    return 0;\n"
    set out to out attach "}\n"
    return out
end

# ============================================================
# COMPILE PIPELINE: Source → AST → IR → C99 → Binary
# ============================================================

print "▸ Stage 1: Lexing..."
tokenize()
print "  ✓ " attach length(tokens) attach " tokens"
print ""

print "▸ Stage 2: Parsing..."
create variable ast as map with value parse_program()
create variable ast_stmts as list with value get_key(ast, "statements")
print "  ✓ " attach length(ast_stmts) attach " AST statements"
print ""

print "▸ Stage 2.5: Symbol Pass (Pass 1 - Declaration)..."
# Reset symbol table for fresh compilation
set next_symbol_id to 1
set next_scope_id to 1
set scopes to map()
set symbols to map()
set current_scope_id to 0
set_key(scopes, 0, map("id", 0, "parent_id", -1, "syms", map(), "level", 0))

# Run Pass 1: collect all declarations
reset_errors()
pass1_declare(ast)
print "  ✓ Symbols declared: " attach (next_symbol_id - 1)
when has_errors() do
    print "  ✗ Pass 1 failed with " attach compiler_errors attach " error(s)"
    return ""
end

print ""

print "▸ Stage 2.6: Symbol Pass (Pass 2 - Resolution)..."
# Reset scope for Pass 2 (fresh resolution pass)
set current_scope_id to 0
reset_errors()
create variable resolved_ast as map with value pass2_resolve(ast)
print "  ✓ AST resolved to SymbolRef"
when has_errors() do
    print "  ✗ Pass 2 failed with " attach compiler_errors attach " error(s)"
    return ""
end

# Check return path completeness
print "▸ Stage 2.7: Return Path Check..."
check_return_paths(resolved_ast)
when has_errors() do
    print "  ✗ Return path check failed with " attach compiler_errors attach " error(s)"
    return ""
end
print "  ✓ Return paths OK"

print ""

print "▸ Stage 3: AST → IR Transformation..."
create variable ir_module as map with value ast_to_ir_program(resolved_ast)
print "  ✓ IR generated"

# Optional: Debug IR dump (set debug_ir to true to enable)
create variable debug_ir as boolean with value false
when debug_ir equals true do
    print ""
    print dump_ir_module(ir_module)
end

create variable ir_funcs as list with value get_key(ir_module, "functions")
create variable ir_globals as list with value get_key(ir_module, "globals")
print "  ✓ IR Module: " attach length(ir_funcs) attach " functions, " attach length(ir_globals) attach " globals"
print ""

print "▸ Stage 3.4: Type Checking..."
type_check_ir(ir_module)
when has_errors() do
    print ""
    print "COMPILATION FAILED: Type errors detected"
    stop
end
print "  ✓ Types verified"
print ""

print "▸ Stage 3.45: Constant Propagation..."
create variable ir_module_propagated as map with value propagate_ir_module(ir_module)
print "  ✓ Constants propagated"
print ""

print "▸ Stage 3.5: IR Optimization (Constant Folding)..."
create variable ir_module_optimized as map with value optimize_ir_module(ir_module_propagated)
print "  ✓ IR optimized"
print ""

print "▸ Stage 3.6: Dead Code Elimination..."
create variable ir_module_dce as map with value eliminate_dead_code_module(ir_module_optimized)
print "  ✓ Dead code eliminated"
print ""

print "▸ Stage 4: IR → C99 Code Generation..."
create variable c_output as text with value ir_module_to_c(ir_module_dce)
create variable c_output as text with value ir_module_to_c(ir_module_optimized)
print "  ✓ C code generated"
print ""

# Output
create variable c_file as text with value "target/output_ir.c"
create variable binary_file as text with value "target/output_ir"

system("mkdir -p target")
print "▸ Stage 5: Saving C code..."
write_file(c_file, c_output)
print "  ✓ Saved to " attach c_file
print ""

print "▸ Stage 6: Compiling to binary..."
create variable compile_cmd as text with value "gcc -o " attach binary_file attach " " attach c_file attach " -lm"
create variable compile_result as integer with value system(compile_cmd)
when compile_result equals 0 do
    print "  ✓ Native binary: " attach binary_file
    print ""
    print "  Running: ./" attach binary_file
    print ""
    create variable run_result as integer with value system("./" attach binary_file)
    print ""
    print "╔══════════════════════════════════════════╗"
    print "║  ✓ IR PIPELINE SUCCESS                    ║"
    print "║  Source → AST → IR → C99 → Binary ✓       ║"
    print "╚══════════════════════════════════════════╝"
otherwise do
    print "  ✗ Compilation failed (code: " attach compile_result attach ")"
end
